---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import FicheCard from '../components/FicheCard.astro';

const themes = [
  {
    title: "Fondations & Manifeste",
    description: "Critique de la modernité et propositions structurelles.",
    fiches: [
      { title: "Manifeste — Plan d'action", author: "Synthèse & Fiqh comparé", year: "v6.0", href: "/fiches/manifeste", color: "#1c1917" }
    ]
  },
  {
    title: "Épistémologie & Théologie",
    description: "La critique de la raison et les fondements de la croyance.",
    fiches: [
      { title: "L'Incohérence des Philosophes", author: "Al-Ghazâlî", year: "1095", href: "/fiches/ghazali-tahafut", color: "#c89a20" }
    ]
  },
  {
    title: "Culture & Domination",
    description: "Comment la culture et l'industrie nous font accepter le système.",
    fiches: [
      { title: "Sur la télévision", author: "Pierre Bourdieu", year: "1996", href: "/fiches/bourdieu-television", color: "#1c1917" },
      { title: "L'Hégémonie Culturelle", author: "Antonio Gramsci", year: "1929", href: "/fiches/gramsci-hegemonie", color: "#1c1917" },
      { title: "L'Industrie Culturelle", author: "Adorno & Horkheimer", year: "1947", href: "/fiches/adorno-horkheimer", color: "#1c1917" }
    ]
  },
  {
    title: "Épistémologie & Philosophie du Langage",
    description: "L'analyse des règles qui conditionnent ce qu'il est possible de dire et de penser à une époque donnée.",
    fiches: [
      { title: "L'Archéologie du Savoir", author: "Michel Foucault", year: "1969", href: "/fiches/foucault-archeologie-du-savoir", color: "#2a8a5a" }
    ]
  },
  {
    title: "Histoire, Sociologie & Philosophie Politique",
    description: "L'étude des lois qui gouvernent la naissance, le développement et le déclin des civilisations et des empires.",
    fiches: [
      { title: "Les Prolégomènes (Muqaddima)", author: "Ibn Khaldoun", year: "1377", href: "/fiches/ibn-khaldoun-prolegomenes", color: "#b54a1a" }
    ]
},
  {
    title: "Pouvoir & Biopolitique",
    description: "Le déplacement du contrôle des territoires vers le contrôle de la vie.",
    fiches: [
      { title: "La nouvelle raison du monde", author: "Dardot & Laval", year: "2009", href: "/fiches/dardot-laval", color: "#1c1917" },
      { title: "Naissance de la biopolitique", author: "Michel Foucault", year: "1979", href: "/fiches/foucault-pouvoir", color: "#1c1917" }
    ]
  },
  {
    title: "Contrôle & Réseaux",
    description: "Le passage de l'enfermement physique au contrôle par le flux.",
    fiches: [
      { title: "La Société du Spectacle", author: "Guy Debord", year: "1967", href: "/fiches/debord-spectacle", color: "#1c1917" },
      { title: "Sociétés de Contrôle", author: "Gilles Deleuze", year: "1990", href: "/fiches/deleuze-controle", color: "#1c1917" },
      { title: "Understanding Media", author: "Marshall McLuhan", year: "1964", href: "/fiches/mcluhan-media", color: "#1c1917" }
    ]
  },
  {
    title: "Histoire & Cycles",
    description: "La naissance et la mort des solidarités collectives.",
    fiches: [
      { title: "La 'Asabiya", author: "Ibn Khaldoun", year: "1377", href: "/fiches/ibn-khaldoun", color: "#1c1917" },
      { title: "Anatomie des Dystopies", author: "Orwell & Huxley", year: "1932", href: "/fiches/orwell-huxley", color: "#1c1917" }
    ]
  }
];
---

<BaseLayout title="Archive Critique" description="Cartographie des mécanismes de pouvoir.">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400..800;1,400..800&display=swap');
  </style>

  <main class="premium-main">
    <header class="premium-hero reveal">
      <div class="hero-badge">Base de données v6.0</div>
      <h1 class="hero-title">L'Archive <span class="text-gold">Critique.</span></h1>
      <p class="hero-desc">Une cartographie rigoureuse des mécanismes de pouvoir, de domination et de subjectivation.</p>
      
      <div class="hero-actions">
        <a href="/fiches/manifeste" class="btn-primary">Lire le Manifeste</a>
        <a href="/corpus" class="btn-secondary">Explorer le Corpus</a>
      </div>
    </header>

    <div class="premium-content">
      {themes.map((theme, index) => (
        <section class="theme-section reveal" style={`--delay: ${index * 0.1}s`}>
          <div class="theme-header">
            <h2 class="theme-title">{theme.title}</h2>
            <p class="theme-desc">{theme.description}</p>
          </div>
          
          <div class="theme-grid">
            {theme.fiches.map((fiche) => (
              <div class="card-wrapper">
                <FicheCard 
                  title={fiche.title} 
                  author={fiche.author} 
                  year={fiche.year} 
                  href={fiche.href} 
                  color={fiche.color} 
                />
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>
  </main>
</BaseLayout>

<style is:global>
  /* ─── PALETTE PREMIUM ATHAR ─── */
  :root {
    --bg-app: #0a0a0a; /* Noir très profond */
    --bg-card: #141414; /* Gris très sombre pour les éléments surélevés */
    --bg-card-hover: #1c1c1c;
    --accent-gold: #d4af37; /* Or luxueux */
    --accent-gold-hover: #e5c048;
    --text-pure: #ffffff;
    --text-dim: #a1a1aa; /* Gris clair pour les sous-titres */
    --border-subtle: #27272a;
  }

  body {
    background-color: var(--bg-app) !important;
    color: var(--text-pure) !important;
    font-family: 'Inter', sans-serif !important;
    -webkit-font-smoothing: antialiased;
  }

  /* ─── LAYOUT GLOBAL ─── */
  .premium-main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 6rem 2rem 8rem;
  }

  /* ─── EN-TÊTE (HERO) ─── */
  .premium-hero {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 24px;
    padding: 4rem 3rem;
    margin-bottom: 5rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
  }

  .hero-badge {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-gold);
    border: 1px solid rgba(212, 175, 55, 0.3);
    padding: 0.4rem 1rem;
    border-radius: 100px;
    margin-bottom: 2rem;
    background: rgba(212, 175, 55, 0.05);
  }

  .hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3rem, 6vw, 4.5rem);
    font-weight: 600;
    color: var(--text-pure);
    margin-bottom: 1rem;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .text-gold {
    color: var(--accent-gold);
  }

  .hero-desc {
    font-size: 1.1rem;
    color: var(--text-dim);
    max-width: 600px;
    line-height: 1.6;
    margin-bottom: 3rem;
  }

  /* Boutons style Dashboard */
  .hero-actions {
    display: flex;
    gap: 1rem;
  }

  .btn-primary, .btn-secondary {
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    padding: 0.8rem 1.5rem;
    border-radius: 12px;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background-color: var(--accent-gold);
    color: #000000;
  }

  .btn-primary:hover {
    background-color: var(--accent-gold-hover);
    transform: translateY(-2px);
  }

  .btn-secondary {
    background-color: transparent;
    color: var(--text-pure);
    border: 1px solid var(--border-subtle);
  }

  .btn-secondary:hover {
    background-color: rgba(255, 255, 255, 0.05);
  }

  /* ─── SECTIONS & GRILLES ─── */
  .premium-content {
    display: flex;
    flex-direction: column;
    gap: 5rem;
  }

  .theme-header {
    margin-bottom: 2rem;
    padding-left: 1rem;
    border-left: 3px solid var(--accent-gold);
  }

  .theme-title {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .theme-desc {
    color: var(--text-dim);
    font-size: 1rem;
  }

  .theme-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  /* ─── FORÇAGE STYLES FICHECARD ─── */
  /* On écrase totalement le style par défaut de ton composant pour coller au thème */
  :global(.fiche-card) {
    background: var(--bg-card) !important;
    border: 1px solid var(--border-subtle) !important;
    border-radius: 20px !important; /* Bords bien arrondis comme la ref */
    padding: 2rem !important;
    display: flex !important;
    flex-direction: column !important;
    height: 100% !important;
    transition: all 0.3s ease !important;
    box-shadow: none !important;
  }

  :global(.fiche-card:hover) {
    background: var(--bg-card-hover) !important;
    border-color: rgba(212, 175, 55, 0.4) !important; /* Bordure dorée au survol */
    transform: translateY(-3px) !important;
  }

  /* Cacher les fonds colorés d'origine si présents */
  :global(.fiche-card .fc-bg) { display: none !important; }

  :global(.fiche-card .fc-title) {
    font-family: 'Playfair Display', serif !important;
    font-size: 1.4rem !important;
    font-weight: 600 !important;
    color: var(--text-pure) !important;
    line-height: 1.3 !important;
    margin-bottom: 1rem !important;
  }

  :global(.fiche-card .fc-author) {
    font-family: 'Inter', sans-serif !important;
    font-size: 0.9rem !important;
    color: var(--text-dim) !important;
    margin-top: auto !important;
    margin-bottom: 1rem !important;
  }

  :global(.fiche-card .fc-year) {
    font-family: 'Inter', sans-serif !important;
    font-size: 0.75rem !important;
    font-weight: 500 !important;
    color: var(--text-pure) !important;
    background: #27272a !important;
    padding: 0.3rem 0.8rem !important;
    border-radius: 8px !important;
    display: inline-block !important;
    align-self: flex-start !important;
  }

  /* ─── ANIMATIONS ─── */
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUp 0.8s ease-out forwards;
    animation-delay: var(--delay, 0s);
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 768px) {
    .premium-hero { padding: 3rem 2rem; }
    .hero-actions { flex-direction: column; }
    .btn-primary, .btn-secondary { text-align: center; }
  }
</style>