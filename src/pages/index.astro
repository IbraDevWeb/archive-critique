---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import FicheCard from '../components/FicheCard.astro';

const themes = [
  {
    title: "Fondations & Manifeste",
    description: "Critique de la modernité et propositions structurelles.",
    fiches: [
      { title: "Manifeste — Plan d'action", author: "Synthèse & Fiqh comparé", year: "v6.0", href: "/fiches/manifeste", color: "#1c1917" }
    ]
  },
  {
    title: "Épistémologie & Théologie",
    description: "La critique de la raison et les fondements de la croyance.",
    fiches: [
      { title: "L'Incohérence des Philosophes", author: "Al-Ghazâlî", year: "1095", href: "/fiches/ghazali-tahafut", color: "#c89a20" }
    ]
  },
  {
    title: "Culture & Domination",
    description: "Comment la culture et l'industrie nous font accepter le système.",
    fiches: [
      { title: "Sur la télévision", author: "Pierre Bourdieu", year: "1996", href: "/fiches/bourdieu-television", color: "#1c1917" },
      { title: "L'Hégémonie Culturelle", author: "Antonio Gramsci", year: "1929", href: "/fiches/gramsci-hegemonie", color: "#1c1917" },
      { title: "L'Industrie Culturelle", author: "Adorno & Horkheimer", year: "1947", href: "/fiches/adorno-horkheimer", color: "#1c1917" }
    ]
  },
  {
    title: "Épistémologie & Philosophie du Langage",
    description: "L'analyse des règles qui conditionnent ce qu'il est possible de dire et de penser à une époque donnée.",
    fiches: [
      { title: "L'Archéologie du Savoir", author: "Michel Foucault", year: "1969", href: "/fiches/foucault-archeologie-du-savoir", color: "#2a8a5a" }
    ]
  },
  {
    title: "Pouvoir & Biopolitique",
    description: "Le déplacement du contrôle des territoires vers le contrôle de la vie.",
    fiches: [
      { title: "La nouvelle raison du monde", author: "Dardot & Laval", year: "2009", href: "/fiches/dardot-laval", color: "#1c1917" },
      { title: "Naissance de la biopolitique", author: "Michel Foucault", year: "1979", href: "/fiches/foucault-pouvoir", color: "#1c1917" }
    ]
  },
  {
    title: "Contrôle & Réseaux",
    description: "Le passage de l'enfermement physique au contrôle par le flux.",
    fiches: [
      { title: "La Société du Spectacle", author: "Guy Debord", year: "1967", href: "/fiches/debord-spectacle", color: "#1c1917" },
      { title: "Sociétés de Contrôle", author: "Gilles Deleuze", year: "1990", href: "/fiches/deleuze-controle", color: "#1c1917" },
      { title: "Understanding Media", author: "Marshall McLuhan", year: "1964", href: "/fiches/mcluhan-media", color: "#1c1917" }
    ]
  },
  {
    title: "Histoire & Cycles",
    description: "La naissance et la mort des solidarités collectives.",
    fiches: [
      { title: "La 'Asabiya", author: "Ibn Khaldoun", year: "1377", href: "/fiches/ibn-khaldoun", color: "#1c1917" },
      { title: "Anatomie des Dystopies", author: "Orwell & Huxley", year: "1932", href: "/fiches/orwell-huxley", color: "#1c1917" }
    ]
  }
];
---

<BaseLayout title="Archive Critique" description="Cartographie des mécanismes de pouvoir.">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&display=swap');
  </style>

  <div class="ambient-background"></div>

  <main class="editorial-main">
    <header class="editorial-hero reveal">
      <div class="hero-badge">Index — v6.0</div>
      <h1 class="hero-title">Archive Critique</h1>
      <p class="hero-desc">Une cartographie des mécanismes de pouvoir, de domination et de subjectivation. Base de données théorique en accès libre.</p>
      <div class="hero-separator"></div>
    </header>

    <div class="editorial-content">
      {themes.map((theme, index) => (
        <section class="theme-section reveal" style={`--delay: ${index * 0.15}s`}>
          <div class="theme-header">
            <h2 class="theme-title">{theme.title}</h2>
            <p class="theme-desc">{theme.description}</p>
          </div>
          
          <div class="theme-grid">
            {theme.fiches.map((fiche) => (
              <div class="card-wrapper">
                <FicheCard 
                  title={fiche.title} 
                  author={fiche.author} 
                  year={fiche.year} 
                  href={fiche.href} 
                  color={fiche.color} 
                />
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>
  </main>
</BaseLayout>

<style is:global>
  /* ─── FONDATION SOMBRE & ÉLÉGANTE ─── */
  :root {
    --bg-base: #050505;
    --text-primary: #f0ebe1;
    --text-secondary: #a3a3a3;
    --border-dim: rgba(255, 255, 255, 0.06);
    --border-glow: rgba(255, 255, 255, 0.15);
    --card-bg: rgba(20, 20, 20, 0.6);
  }

  body {
    background-color: var(--bg-base) !important;
    color: var(--text-primary) !important;
    font-family: 'Inter', sans-serif !important;
    position: relative;
    overflow-x: hidden;
  }

  /* Gradient de fond subtil pour la profondeur */
  .ambient-background {
    position: fixed;
    top: -20vh;
    left: 50%;
    transform: translateX(-50%);
    width: 100vw;
    height: 60vh;
    background: radial-gradient(ellipse at top, rgba(30, 30, 35, 0.4) 0%, transparent 70%);
    z-index: -1;
    pointer-events: none;
  }

  /* ─── LAYOUT DE LA PAGE ─── */
  .editorial-main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 10rem 2rem 8rem;
  }

  .editorial-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: 8rem;
  }

  .hero-badge {
    font-size: 0.65rem;
    font-family: 'JetBrains Mono', monospace, sans-serif;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-secondary);
    border: 1px solid var(--border-dim);
    padding: 0.4rem 1rem;
    border-radius: 100px;
    margin-bottom: 2rem;
  }

  .hero-title {
    font-family: 'Newsreader', serif;
    font-size: clamp(3.5rem, 8vw, 5.5rem);
    font-weight: 300;
    letter-spacing: -0.03em;
    color: #ffffff;
    margin-bottom: 1.5rem;
    line-height: 1.1;
  }

  .hero-desc {
    font-size: 1.15rem;
    font-weight: 300;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto;
  }

  .hero-separator {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, var(--border-glow), transparent);
    margin-top: 4rem;
  }

  .editorial-content {
    display: flex;
    flex-direction: column;
    gap: 7rem;
  }

  /* ─── SECTIONS THÉMATIQUES ─── */
  .theme-header {
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .theme-title {
    font-family: 'Newsreader', serif;
    font-size: 2.2rem;
    font-weight: 400;
    color: #ffffff;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }

  .theme-desc {
    font-size: 1.05rem;
    font-weight: 300;
    color: var(--text-secondary);
    max-width: 600px;
  }

  .theme-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  /* ─── STYLISATION OVERRIDE DES CARTES (FicheCard) ─── */
  :global(.fiche-card) {
    background: var(--card-bg) !important;
    backdrop-filter: blur(10px) !important;
    -webkit-backdrop-filter: blur(10px) !important;
    border: 1px solid var(--border-dim) !important;
    border-radius: 8px !important;
    padding: 2.5rem 2rem !important;
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1) !important;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1) !important;
    display: flex !important;
    flex-direction: column !important;
    height: 100% !important;
  }

  /* Effet de survol élégant */
  :global(.fiche-card:hover) {
    border-color: var(--border-glow) !important;
    background: rgba(30, 30, 30, 0.8) !important;
    transform: translateY(-4px) !important;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.4) !important;
  }

  /* Suppression du fond de couleur initial de la carte si existant */
  :global(.fiche-card .fc-bg) { 
    display: none !important;
  }

  /* Textes internes de la carte */
  :global(.fiche-card .fc-title) {
    font-family: 'Newsreader', serif !important;
    font-size: 1.6rem !important;
    font-weight: 400 !important;
    color: #ffffff !important;
    line-height: 1.3 !important;
    margin-bottom: 1rem !important;
    letter-spacing: -0.01em !important;
  }

  :global(.fiche-card .fc-author) {
    font-family: 'Inter', sans-serif !important;
    font-size: 0.95rem !important;
    font-weight: 400 !important;
    color: var(--text-secondary) !important;
    margin-bottom: 1.5rem !important;
    margin-top: auto !important; /* Pousse l'auteur/année vers le bas */
  }

  :global(.fiche-card .fc-year) {
    font-family: 'JetBrains Mono', monospace, sans-serif !important;
    font-size: 0.7rem !important;
    color: var(--text-secondary) !important;
    background: transparent !important;
    border: 1px solid var(--border-dim) !important;
    padding: 0.3rem 0.6rem !important;
    border-radius: 4px !important;
    letter-spacing: 0.1em !important;
    display: inline-block !important;
  }

  /* ─── ANIMATIONS ─── */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--delay, 0s);
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 768px) {
    .editorial-main { padding: 6rem 1.5rem; }
    .hero-title { font-size: 2.8rem; }
    .editorial-content { gap: 5rem; }
    .theme-header { margin-bottom: 2rem; }
  }
</style>