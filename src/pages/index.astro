---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import FicheCard from '../components/FicheCard.astro';

const themes = [
  {
    title: "Manifeste & Fondations",
    description: "Critique de la modernité et propositions structurelles.",
    fiches: [
      { title: "Manifeste — Plan d'action", author: "Synthèse & Fiqh comparé", year: "v6.0", href: "/fiches/manifeste", color: "#6b7280" }
    ]
  },
  {
    title: "Culture & Domination",
    description: "Comment la culture et l'industrie nous font accepter le système.",
    fiches: [
      { title: "Sur la télévision", author: "Pierre Bourdieu", year: "1996", href: "/fiches/bourdieu-television", color: "#6b7280" },
      { title: "L'Hégémonie Culturelle", author: "Antonio Gramsci", year: "1929", href: "/fiches/gramsci-hegemonie", color: "#6b7280" },
      { title: "L'Industrie Culturelle", author: "Adorno & Horkheimer", year: "1947", href: "/fiches/adorno-horkheimer", color: "#6b7280" }
    ]
  },
  {
    title: "Pouvoir & Biopolitique",
    description: "Le déplacement du contrôle des territoires vers le contrôle de la vie.",
    fiches: [
      { title: "La nouvelle raison du monde", author: "Dardot & Laval", year: "2009", href: "/fiches/dardot-laval", color: "#6b7280" },
      { title: "Naissance de la biopolitique", author: "Michel Foucault", year: "1979", href: "/fiches/foucault-pouvoir", color: "#6b7280" }
    ]
  },
  {
    title: "Contrôle & Réseaux",
    description: "Le passage de l'enfermement physique au contrôle par le flux.",
    fiches: [
      { title: "La Société du Spectacle", author: "Guy Debord", year: "1967", href: "/fiches/debord-spectacle", color: "#6b7280" },
      { title: "Sociétés de Contrôle", author: "Gilles Deleuze", year: "1990", href: "/fiches/deleuze-controle", color: "#6b7280" },
      { title: "Understanding Media", author: "Marshall McLuhan", year: "1964", href: "/fiches/mcluhan-media", color: "#6b7280" }
    ]
  },
  {
    title: "Histoire & Cycles",
    description: "La naissance et la mort des solidarités collectives.",
    fiches: [
      { title: "La 'Asabiya", author: "Ibn Khaldoun", year: "1377", href: "/fiches/ibn-khaldoun", color: "#6b7280" },
      { title: "Anatomie des Dystopies", author: "Orwell & Huxley", year: "1932", href: "/fiches/orwell-huxley", color: "#6b7280" }
    ]
  }
];
---

<BaseLayout title="Archive Critique" description="Cartographie des mécanismes de pouvoir.">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Playfair+Display:ital,wght@0,400;0,600;1,400;1,600&display=swap');
  </style>

  <main class="refined-main">
    
    <header class="refined-hero reveal">
      <h1 class="hero-title">Archive Critique</h1>
      <p class="hero-desc">Une cartographie des mécanismes de pouvoir, de domination et de subjectivation. Une base de données théorique en accès libre.</p>
    </header>

    <div class="refined-content">
      {themes.map((theme, index) => (
        <section class="theme-section reveal" style={`--delay: ${index * 0.1}s`}>
          <div class="theme-header">
            <h2 class="theme-title">{theme.title}</h2>
            <p class="theme-desc">{theme.description}</p>
          </div>
          
          <div class="theme-grid">
            {theme.fiches.map((fiche) => (
              <div class="card-container">
                <FicheCard 
                  title={fiche.title} 
                  author={fiche.author} 
                  year={fiche.year} 
                  href={fiche.href} 
                  color={fiche.color} 
                />
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>

  </main>

</BaseLayout>

<style is:global>
  /* ─── PURGE DES STYLES GLOBAUX POUR LA PAGE D'ACCUEIL ─── */
  :root {
    --bg-pure: #ffffff;
    --text-main: #111827;
    --text-muted: #6b7280;
    --border-soft: #f3f4f6;
    --border-mid: #e5e7eb;
  }

  body {
    background-color: var(--bg-pure) !important;
    color: var(--text-main) !important;
    font-family: 'Inter', sans-serif !important;
  }

  /* Curseur minimaliste */
  .cur-base {
    width: 8px !important;
    height: 8px !important;
    background: var(--text-main) !important;
    border: none !important;
    opacity: 0.3;
  }
  .cur-base.big {
    width: 40px !important;
    height: 40px !important;
    background: rgba(0,0,0,0.04) !important;
    opacity: 1;
  }

  /* ─── OVERRIDE TOTAL DES CARTES (FicheCard) ─── */
  /* On force le composant FicheCard à adopter un design pur et moderne */
  :global(.fiche-card) {
    background: #ffffff !important;
    border: 1px solid var(--border-mid) !important;
    border-radius: 12px !important; /* Bords doucement arrondis */
    padding: 2rem !important;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02), 0 2px 4px -1px rgba(0, 0, 0, 0.02) !important;
    color: var(--text-main) !important;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
    display: flex !important;
    flex-direction: column !important;
    justify-content: space-between !important;
    min-height: 200px !important;
  }

  :global(.fiche-card:hover) {
    border-color: #d1d5db !important;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05), 0 4px 6px -2px rgba(0, 0, 0, 0.03) !important;
    transform: translateY(-4px) !important;
  }

  /* Suppression du fond coloré brutaliste de l'ancien design */
  :global(.fiche-card .fc-bg) {
    display: none !important;
  }

  /* Textes à l'intérieur de la carte */
  :global(.fiche-card .fc-year) {
    font-family: 'Inter', sans-serif !important;
    font-size: 0.75rem !important;
    font-weight: 500 !important;
    letter-spacing: 0.05em !important;
    color: var(--text-muted) !important;
    background: var(--border-soft) !important;
    padding: 0.2rem 0.6rem !important;
    border-radius: 100px !important;
  }

  :global(.fiche-card .fc-icon) {
    color: #9ca3af !important;
    font-size: 1rem !important;
  }

  :global(.fiche-card .fc-title) {
    font-family: 'Playfair Display', serif !important;
    font-size: 1.5rem !important;
    font-weight: 600 !important;
    color: var(--text-main) !important;
    line-height: 1.3 !important;
    text-transform: none !important;
    letter-spacing: normal !important;
    margin-bottom: 0.5rem !important;
  }

  :global(.fiche-card .fc-author) {
    font-family: 'Inter', sans-serif !important;
    font-size: 0.9rem !important;
    font-style: normal !important;
    color: var(--text-muted) !important;
  }

  /* ─── LAYOUT DE LA PAGE ─── */
  .refined-main {
    max-width: 1000px;
    margin: 0 auto;
    padding: 8rem 2rem 6rem;
  }

  .refined-hero {
    text-align: center;
    margin-bottom: 6rem;
    animation: fadeUp 1s ease-out forwards;
  }

  .hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3rem, 6vw, 4.5rem);
    font-weight: 600;
    color: var(--text-main);
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .hero-desc {
    font-family: 'Inter', sans-serif;
    font-size: 1.1rem;
    font-weight: 300;
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 600px;
    margin: 0 auto;
  }

  /* ─── SECTIONS ─── */
  .refined-content {
    display: flex;
    flex-direction: column;
    gap: 5rem;
  }

  .theme-section {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUp 0.8s ease-out forwards;
    animation-delay: var(--delay);
  }

  .theme-header {
    margin-bottom: 2.5rem;
    text-align: center;
  }

  .theme-title {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    font-weight: 600;
    color: var(--text-main);
    margin-bottom: 0.5rem;
  }

  .theme-desc {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    font-weight: 300;
    color: var(--text-muted);
  }

  .theme-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .refined-main { padding: 4rem 1.5rem; }
    .theme-grid { grid-template-columns: 1fr; }
  }
</style>