---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import FicheCard from '../components/FicheCard.astro';

const themes = [
  {
    title: "Fondations & Manifeste",
    description: "Critique de la modernité et propositions structurelles.",
    fiches: [
      { title: "Manifeste — Plan d'action", author: "Synthèse & Fiqh comparé", year: "v6.0", href: "/fiches/manifeste", color: "#1c1917" }
    ]
  },
  {
    title: "Épistémologie & Théologie",
    description: "La critique de la raison et les fondements de la croyance.",
    fiches: [
      { title: "L'Incohérence des Philosophes", author: "Al-Ghazâlî", year: "1095", href: "/fiches/ghazali-tahafut", color: "#c89a20" }
    ]
  },
  {
    title: "Culture & Domination",
    description: "Comment la culture et l'industrie nous font accepter le système.",
    fiches: [
      { title: "Sur la télévision", author: "Pierre Bourdieu", year: "1996", href: "/fiches/bourdieu-television", color: "#1c1917" },
      { title: "L'Hégémonie Culturelle", author: "Antonio Gramsci", year: "1929", href: "/fiches/gramsci-hegemonie", color: "#1c1917" },
      { title: "L'Industrie Culturelle", author: "Adorno & Horkheimer", year: "1947", href: "/fiches/adorno-horkheimer", color: "#1c1917" }
    ]
  },
  {
    title: "Épistémologie & Philosophie du Langage",
    description: "L'analyse des règles qui conditionnent ce qu'il est possible de dire et de penser à une époque donnée.",
    fiches: [
      { title: "L'Archéologie du Savoir", author: "Michel Foucault", year: "1969", href: "/fiches/foucault-archeologie-du-savoir", color: "#2a8a5a" }
    ]
  },
  {
    title: "Pouvoir & Biopolitique",
    description: "Le déplacement du contrôle des territoires vers le contrôle de la vie.",
    fiches: [
      { title: "La nouvelle raison du monde", author: "Dardot & Laval", year: "2009", href: "/fiches/dardot-laval", color: "#1c1917" },
      { title: "Naissance de la biopolitique", author: "Michel Foucault", year: "1979", href: "/fiches/foucault-pouvoir", color: "#1c1917" }
    ]
  },
  {
    title: "Contrôle & Réseaux",
    description: "Le passage de l'enfermement physique au contrôle par le flux.",
    fiches: [
      { title: "La Société du Spectacle", author: "Guy Debord", year: "1967", href: "/fiches/debord-spectacle", color: "#1c1917" },
      { title: "Sociétés de Contrôle", author: "Gilles Deleuze", year: "1990", href: "/fiches/deleuze-controle", color: "#1c1917" },
      { title: "Understanding Media", author: "Marshall McLuhan", year: "1964", href: "/fiches/mcluhan-media", color: "#1c1917" }
    ]
  },
  {
    title: "Histoire & Cycles",
    description: "La naissance et la mort des solidarités collectives.",
    fiches: [
      { title: "La 'Asabiya", author: "Ibn Khaldoun", year: "1377", href: "/fiches/ibn-khaldoun", color: "#1c1917" },
      { title: "Anatomie des Dystopies", author: "Orwell & Huxley", year: "1932", href: "/fiches/orwell-huxley", color: "#1c1917" }
    ]
  }
];
---

<BaseLayout title="Archive Critique" description="Cartographie des mécanismes de pouvoir.">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&display=swap');
  </style>

  <main class="classic-main">
    <header class="classic-hero reveal">
      <div class="hero-surtitle">Index Général — v6.0</div>
      <h1 class="hero-title">Archive Critique</h1>
      <p class="hero-desc">Une cartographie des mécanismes de pouvoir, de domination et de subjectivation. Base de données théorique en accès libre.</p>
      <div class="hero-ornament"></div>
    </header>

    <div class="classic-content">
      {themes.map((theme, index) => (
        <section class="theme-section reveal" style={`--delay: ${index * 0.15}s`}>
          <div class="theme-header">
            <h2 class="theme-title">{theme.title}</h2>
            <p class="theme-desc">{theme.description}</p>
          </div>
          
          <div class="theme-grid">
            {theme.fiches.map((fiche) => (
              <div class="card-wrapper">
                <FicheCard 
                  title={fiche.title} 
                  author={fiche.author} 
                  year={fiche.year} 
                  href={fiche.href} 
                  color={fiche.color} 
                />
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>
  </main>
</BaseLayout>

<style is:global>
  /* ─── FONDATION PAPIER / LITTÉRAIRE ─── */
  :root {
    --bg-paper: #FDFbf7; /* Blanc cassé très chaud, type page de livre */
    --text-ink: #1c1917; /* Gris très foncé, plus doux que le noir pur */
    --text-muted: #78716c; /* Gris taupe pour les éléments secondaires */
    --border-light: #e7e5e4;
    --border-dark: #d6d3d1;
    --card-bg: #ffffff;
  }

  body {
    background-color: var(--bg-paper) !important;
    color: var(--text-ink) !important;
    font-family: 'Inter', sans-serif !important;
  }

  /* ─── LAYOUT DE LA PAGE ─── */
  .classic-main {
    max-width: 1000px;
    margin: 0 auto;
    padding: 8rem 2rem 6rem;
  }

  .classic-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: 7rem;
  }

  .hero-surtitle {
    font-size: 0.75rem;
    font-family: 'Inter', sans-serif;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 2rem;
  }

  .hero-title {
    font-family: 'Newsreader', serif;
    font-size: clamp(3.5rem, 8vw, 5rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--text-ink);
    margin-bottom: 1.5rem;
    line-height: 1.1;
  }

  .hero-desc {
    font-size: 1.1rem;
    font-weight: 300;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 580px;
    margin: 0 auto;
  }

  /* Petit trait de séparation élégant au lieu d'une grande barre */
  .hero-ornament {
    width: 40px;
    height: 1px;
    background-color: var(--text-ink);
    margin-top: 3.5rem;
    opacity: 0.3;
  }

  .classic-content {
    display: flex;
    flex-direction: column;
    gap: 6rem;
  }

  /* ─── SECTIONS THÉMATIQUES ─── */
  .theme-header {
    margin-bottom: 2.5rem;
    border-bottom: 1px solid var(--border-light);
    padding-bottom: 1rem;
  }

  .theme-title {
    font-family: 'Newsreader', serif;
    font-size: 2rem;
    font-weight: 500;
    color: var(--text-ink);
    margin-bottom: 0.5rem;
  }

  .theme-desc {
    font-size: 1.05rem;
    font-weight: 300;
    color: var(--text-muted);
  }

  .theme-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem; /* Plus d'espace entre les cartes pour un rendu moins tassé */
  }

  /* ─── STYLISATION OVERRIDE DES CARTES (FicheCard) ─── */
  :global(.fiche-card) {
    background: var(--card-bg) !important;
    border: 1px solid var(--border-light) !important;
    border-radius: 4px !important; /* Angles moins arrondis, plus "livre" */
    padding: 2.5rem 2rem !important;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02) !important; /* Ombre extrêmement subtile */
    transition: all 0.3s ease !important;
    display: flex !important;
    flex-direction: column !important;
    height: 100% !important;
  }

  /* Effet de survol : la carte remonte légèrement et la bordure s'assombrit */
  :global(.fiche-card:hover) {
    border-color: var(--border-dark) !important;
    transform: translateY(-4px) !important;
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.06) !important;
  }

  /* Suppression du fond de couleur initial de la carte */
  :global(.fiche-card .fc-bg) { 
    display: none !important;
  }

  /* Textes internes de la carte */
  :global(.fiche-card .fc-title) {
    font-family: 'Newsreader', serif !important;
    font-size: 1.5rem !important;
    font-weight: 500 !important;
    color: var(--text-ink) !important;
    line-height: 1.3 !important;
    margin-bottom: 0.8rem !important;
  }

  :global(.fiche-card .fc-author) {
    font-family: 'Inter', sans-serif !important;
    font-size: 0.95rem !important;
    font-weight: 400 !important;
    color: var(--text-muted) !important;
    margin-bottom: 1.5rem !important;
    margin-top: auto !important; 
  }

  /* L'année devient discrète, sans badge lourd */
  :global(.fiche-card .fc-year) {
    font-family: 'Inter', sans-serif !important;
    font-size: 0.8rem !important;
    color: var(--text-muted) !important;
    background: transparent !important;
    border: none !important;
    padding: 0 !important;
    letter-spacing: 0.05em !important;
    display: inline-block !important;
  }

  /* ─── ANIMATIONS ─── */
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUp 0.8s ease-out forwards;
    animation-delay: var(--delay, 0s);
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 768px) {
    .classic-main { padding: 4rem 1.5rem; }
    .hero-title { font-size: 2.8rem; }
    .classic-content { gap: 4rem; }
  }
</style>