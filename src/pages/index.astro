---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import FicheCard from '../components/FicheCard.astro';

const themes = [
  {
    title: "Fondations & Manifeste",
    description: "Critique de la modernité et propositions structurelles.",
    fiches: [
      { title: "Manifeste — Plan d'action", author: "Synthèse & Fiqh comparé", year: "v6.0", href: "/fiches/manifeste", color: "#1c1917" }
    ]
  },
  {
    title: "Épistémologie & Théologie",
    description: "La critique de la raison et les fondements de la croyance.",
    fiches: [
      { title: "L'Incohérence des Philosophes", author: "Al-Ghazâlî", year: "1095", href: "/fiches/ghazali-tahafut", color: "#c89a20" }
    ]
  },
  {
    title: "Culture & Domination",
    description: "Comment la culture et l'industrie nous font accepter le système.",
    fiches: [
      { title: "Sur la télévision", author: "Pierre Bourdieu", year: "1996", href: "/fiches/bourdieu-television", color: "#1c1917" },
      { title: "L'Hégémonie Culturelle", author: "Antonio Gramsci", year: "1929", href: "/fiches/gramsci-hegemonie", color: "#1c1917" },
      { title: "L'Industrie Culturelle", author: "Adorno & Horkheimer", year: "1947", href: "/fiches/adorno-horkheimer", color: "#1c1917" }
    ]
  },
  {
    title: "Épistémologie & Philosophie du Langage",
    description: "L'analyse des règles qui conditionnent ce qu'il est possible de dire et de penser à une époque donnée.",
    fiches: [
      { title: "L'Archéologie du Savoir", author: "Michel Foucault", year: "1969", href: "/fiches/foucault-archeologie-du-savoir", color: "#2a8a5a" }
    ]
  },
  {
    title: "Pouvoir & Biopolitique",
    description: "Le déplacement du contrôle des territoires vers le contrôle de la vie.",
    fiches: [
      { title: "La nouvelle raison du monde", author: "Dardot & Laval", year: "2009", href: "/fiches/dardot-laval", color: "#1c1917" },
      { title: "Naissance de la biopolitique", author: "Michel Foucault", year: "1979", href: "/fiches/foucault-pouvoir", color: "#1c1917" }
    ]
  },
  {
    title: "Contrôle & Réseaux",
    description: "Le passage de l'enfermement physique au contrôle par le flux.",
    fiches: [
      { title: "La Société du Spectacle", author: "Guy Debord", year: "1967", href: "/fiches/debord-spectacle", color: "#1c1917" },
      { title: "Sociétés de Contrôle", author: "Gilles Deleuze", year: "1990", href: "/fiches/deleuze-controle", color: "#1c1917" },
      { title: "Understanding Media", author: "Marshall McLuhan", year: "1964", href: "/fiches/mcluhan-media", color: "#1c1917" }
    ]
  },
  {
    title: "Histoire & Cycles",
    description: "La naissance et la mort des solidarités collectives.",
    fiches: [
      { title: "La 'Asabiya", author: "Ibn Khaldoun", year: "1377", href: "/fiches/ibn-khaldoun", color: "#1c1917" },
      { title: "Anatomie des Dystopies", author: "Orwell & Huxley", year: "1932", href: "/fiches/orwell-huxley", color: "#1c1917" }
    ]
  }
];
---

<BaseLayout title="Archive Critique" description="Cartographie des mécanismes de pouvoir.">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&display=swap');
  </style>

  <main class="clean-main">
    <header class="clean-hero reveal">
      <h1 class="hero-title">Archive Critique</h1>
      <p class="hero-desc">Une cartographie des mécanismes de pouvoir, de domination et de subjectivation. Base de données théorique en accès libre.</p>
    </header>

    <div class="clean-content">
      {themes.map((theme, index) => (
        <section class="theme-section reveal" style={`--delay: ${index * 0.1}s`}>
          <div class="theme-header">
            <h2 class="theme-title">{theme.title}</h2>
            <p class="theme-desc">{theme.description}</p>
          </div>
          
          <div class="theme-grid">
            {theme.fiches.map((fiche) => (
              <FicheCard 
                title={fiche.title} 
                author={fiche.author} 
                year={fiche.year} 
                href={fiche.href} 
                color={fiche.color} 
              />
            ))}
          </div>
        </section>
      ))}
    </div>
  </main>
</BaseLayout>

<style is:global>
  /* ─── THÈME "DARK EDITORIAL" (SOMBRE & ÉLÉGANT) ─── */
  :root {
    --bg-dark: #0a0a0a;       /* Fond noir profond, mais pas pur */
    --text-main: #f3f4f6;     /* Blanc cassé très lisible */
    --text-muted: #9ca3af;    /* Gris doux pour les descriptions */
    --border-subtle: #27272a; /* Bordures à peine visibles */
  }

  body {
    background-color: var(--bg-dark) !important;
    color: var(--text-main) !important;
    font-family: 'Inter', sans-serif !important;
  }

  /* ─── CORRECTION DU CURSEUR GLOBAL ─── */
  .cur-base {
    width: 12px !important; 
    height: 12px !important;
    background: transparent !important;
    border: 2px solid #ffffff !important; /* Bordure blanche bien visible */
    border-radius: 50% !important;
    opacity: 0.7 !important;
    mix-blend-mode: normal !important;
  }
  .cur-base.big {
    width: 44px !important; 
    height: 44px !important;
    background: rgba(255, 255, 255, 0.1) !important;
    border-color: rgba(255, 255, 255, 0.3) !important;
  }

  /* ─── REDESIGN DES CARTES (Contraste parfait) ─── */
  :global(.fiche-card) {
    background: #111111 !important; /* Carte très légèrement plus claire que le fond */
    border: 1px solid var(--border-subtle) !important;
    border-radius: 6px !important;
    padding: 2rem !important;
    box-shadow: none !important;
    transition: all 0.3s ease !important;
  }

  :global(.fiche-card:hover) {
    border-color: #52525b !important;
    background: #18181b !important;
    transform: translateY(-3px) !important;
  }

  /* Désactiver le fond coloré brutaliste */
  :global(.fiche-card .fc-bg) { 
    display: none !important; 
  }

  /* Textes internes de la carte */
  :global(.fiche-card .fc-title) {
    font-family: 'Newsreader', serif !important;
    font-size: 1.5rem !important;
    font-weight: 500 !important;
    color: #ffffff !important; /* Titre blanc pur */
    text-transform: none !important;
    letter-spacing: normal !important;
    line-height: 1.3 !important;
    margin-bottom: 0.5rem !important;
  }

  :global(.fiche-card .fc-author) {
    font-family: 'Inter', sans-serif !important;
    font-size: 0.95rem !important;
    font-style: normal !important;
    color: var(--text-muted) !important;
  }

  :global(.fiche-card .fc-year) {
    font-family: 'Inter', sans-serif !important;
    font-size: 0.75rem !important;
    font-weight: 500 !important;
    color: #e5e7eb !important;
    background: #27272a !important; /* Badge gris sombre */
    padding: 0.2rem 0.6rem !important;
    border-radius: 100px !important;
    letter-spacing: 0.05em !important;
  }

  :global(.fiche-card .fc-icon) {
    color: #52525b !important;
  }

  /* ─── LAYOUT DE LA PAGE D'ACCUEIL ─── */
  .clean-main {
    max-width: 1000px;
    margin: 0 auto;
    padding: 8rem 2rem 6rem;
  }

  .clean-hero {
    text-align: center;
    margin-bottom: 6rem;
  }

  .hero-title {
    font-family: 'Newsreader', serif;
    font-size: clamp(3rem, 6vw, 4.5rem);
    font-weight: 400;
    color: #ffffff;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .hero-desc {
    font-family: 'Inter', sans-serif;
    font-size: 1.1rem;
    font-weight: 300;
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 550px;
    margin: 0 auto;
  }

  .clean-content {
    display: flex;
    flex-direction: column;
    gap: 5rem;
  }

  .theme-section {
    animation-delay: var(--delay);
  }

  .theme-header {
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--border-subtle);
    padding-bottom: 1rem;
  }

  .theme-title {
    font-family: 'Newsreader', serif;
    font-size: 2rem;
    font-weight: 500;
    color: #ffffff;
    margin-bottom: 0.2rem;
  }

  .theme-desc {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    font-weight: 300;
    color: var(--text-muted);
  }

  .theme-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  /* Animations */
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUp 0.8s ease-out forwards;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .clean-main { padding: 4rem 1.5rem; }
    .theme-grid { grid-template-columns: 1fr; }
  }
</style>