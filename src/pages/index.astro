---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import FicheCard from '../components/FicheCard.astro';

const themes = [
  {
    title: "Fondations & Manifeste",
    description: "Critique de la modernité et propositions structurelles.",
    fiches: [
      { title: "Manifeste — Plan d'action", author: "Synthèse & Fiqh comparé", year: "v6.0", href: "/fiches/manifeste", color: "#1c1917" }
    ]
  },
  {
    title: "Culture & Domination",
    description: "Comment la culture et l'industrie nous font accepter le système.",
    fiches: [
      { title: "Sur la télévision", author: "Pierre Bourdieu", year: "1996", href: "/fiches/bourdieu-television", color: "#1c1917" },
      { title: "L'Hégémonie Culturelle", author: "Antonio Gramsci", year: "1929", href: "/fiches/gramsci-hegemonie", color: "#1c1917" },
      { title: "L'Industrie Culturelle", author: "Adorno & Horkheimer", year: "1947", href: "/fiches/adorno-horkheimer", color: "#1c1917" }
    ]
  },
  {
    title: "Pouvoir & Biopolitique",
    description: "Le déplacement du contrôle des territoires vers le contrôle de la vie.",
    fiches: [
      { title: "La nouvelle raison du monde", author: "Dardot & Laval", year: "2009", href: "/fiches/dardot-laval", color: "#1c1917" },
      { title: "Naissance de la biopolitique", author: "Michel Foucault", year: "1979", href: "/fiches/foucault-pouvoir", color: "#1c1917" }
    ]
  },
  {
    title: "Contrôle & Réseaux",
    description: "Le passage de l'enfermement physique au contrôle par le flux.",
    fiches: [
      { title: "La Société du Spectacle", author: "Guy Debord", year: "1967", href: "/fiches/debord-spectacle", color: "#1c1917" },
      { title: "Sociétés de Contrôle", author: "Gilles Deleuze", year: "1990", href: "/fiches/deleuze-controle", color: "#1c1917" },
      { title: "Understanding Media", author: "Marshall McLuhan", year: "1964", href: "/fiches/mcluhan-media", color: "#1c1917" }
    ]
  },
  {
    title: "Histoire & Cycles",
    description: "La naissance et la mort des solidarités collectives.",
    fiches: [
      { title: "La 'Asabiya", author: "Ibn Khaldoun", year: "1377", href: "/fiches/ibn-khaldoun", color: "#1c1917" },
      { title: "Anatomie des Dystopies", author: "Orwell & Huxley", year: "1932", href: "/fiches/orwell-huxley", color: "#1c1917" }
    ]
  }
];
---

<BaseLayout title="Archive Critique" description="Cartographie des mécanismes de pouvoir.">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&display=swap');
  </style>

  <main class="clean-main">
    <header class="clean-hero reveal">
      <h1 class="hero-title">Archive Critique</h1>
      <p class="hero-desc">Une cartographie des mécanismes de pouvoir, de domination et de subjectivation. Base de données théorique en accès libre.</p>
    </header>

    <div class="clean-content">
      {themes.map((theme, index) => (
        <section class="theme-section reveal" style={`--delay: ${index * 0.1}s`}>
          <div class="theme-header">
            <h2 class="theme-title">{theme.title}</h2>
            <p class="theme-desc">{theme.description}</p>
          </div>
          
          <div class="theme-grid">
            {theme.fiches.map((fiche) => (
              <FicheCard 
                title={fiche.title} 
                author={fiche.author} 
                year={fiche.year} 
                href={fiche.href} 
                color={fiche.color} 
              />
            ))}
          </div>
        </section>
      ))}
    </div>
  </main>
</BaseLayout>

<style is:global>
  /* ─── REDÉFINITION DES VARIABLES POUR UN THÈME CLAIR ET LISIBLE ─── */
  :root {
    --void-bg: #fcfcfc;      /* Fond très légèrement chaud pour reposer l'œil */
    --paper-text: #1c1917;   /* Texte gris très foncé (plus doux que le noir pur) */
    --accent-color: #1c1917; /* Accents assortis au texte */
  }

  body {
    background-color: var(--void-bg);
    color: var(--paper-text);
    font-family: 'Inter', sans-serif; /* Police de lecture moderne */
  }

  /* Rendre le curseur global élégant et discret */
  .cur-base {
    width: 10px; height: 10px;
    background: transparent !important;
    border: 1px solid rgba(28, 25, 23, 0.4) !important;
  }
  .cur-base.big {
    background: rgba(28, 25, 23, 0.05) !important;
    border-color: rgba(28, 25, 23, 0.1) !important;
  }

  /* ─── LAYOUT DE LA PAGE ─── */
  .clean-main {
    max-width: 1000px;
    margin: 0 auto;
    padding: 8rem 2rem 6rem;
  }

  /* ─── HERO HEADER ─── */
  .clean-hero {
    text-align: center;
    margin-bottom: 6rem;
  }

  .hero-title {
    font-family: 'Newsreader', serif;
    font-size: clamp(3rem, 6vw, 4.5rem);
    font-weight: 400;
    color: var(--paper-text);
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .hero-desc {
    font-family: 'Inter', sans-serif;
    font-size: 1.1rem;
    font-weight: 300;
    color: #57534e;
    line-height: 1.6;
    max-width: 550px;
    margin: 0 auto;
  }

  /* ─── SECTIONS THÉMATIQUES ─── */
  .clean-content {
    display: flex;
    flex-direction: column;
    gap: 5rem;
  }

  .theme-section {
    animation-delay: var(--delay);
  }

  .theme-header {
    margin-bottom: 2rem;
    border-bottom: 1px solid #e7e5e4;
    padding-bottom: 1rem;
  }

  .theme-title {
    font-family: 'Newsreader', serif;
    font-size: 2rem;
    font-weight: 500;
    color: var(--paper-text);
    margin-bottom: 0.2rem;
  }

  .theme-desc {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    font-weight: 300;
    color: #78716c;
  }

  .theme-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  /* ─── FORÇAGE DU DESIGN DES FICHECARDS (POUR LE THÈME CLAIR) ─── */
  .fiche-card {
    background: #ffffff !important;
    border: 1px solid #e7e5e4 !important;
    border-radius: 8px !important;
    padding: 2rem !important;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02) !important;
    transition: all 0.3s ease !important;
  }

  .fiche-card:hover {
    border-color: #d6d3d1 !important;
    transform: translateY(-3px) !important;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.04) !important;
  }

  /* Désactiver le fond coloré brutaliste */
  .fiche-card .fc-bg { display: none !important; }

  /* Typographie interne des cartes */
  .fiche-card .fc-title {
    font-family: 'Newsreader', serif !important;
    font-size: 1.4rem !important;
    font-weight: 500 !important;
    color: var(--paper-text) !important;
    text-transform: none !important; /* Retire les majuscules agressives */
    letter-spacing: normal !important;
    line-height: 1.3 !important;
    margin-bottom: 0.5rem !important;
  }

  .fiche-card .fc-author {
    font-family: 'Inter', sans-serif !important;
    font-size: 0.95rem !important;
    font-style: normal !important;
    color: #57534e !important;
  }

  .fiche-card .fc-year {
    font-family: 'Inter', sans-serif !important;
    font-size: 0.75rem !important;
    font-weight: 500 !important;
    color: #78716c !important;
    letter-spacing: 0.05em !important;
    background: #f5f5f4 !important;
    padding: 0.2rem 0.6rem !important;
    border-radius: 100px !important;
  }

  .fiche-card .fc-icon {
    color: #d6d3d1 !important;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .clean-main { padding: 4rem 1.5rem; }
    .theme-grid { grid-template-columns: 1fr; }
  }
</style>