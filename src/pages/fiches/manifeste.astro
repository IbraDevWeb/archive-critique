  .roadmap-phase::before { content: ''; position: absolute; left: -2.15rem; top: .4rem; width: 9px; height: 9px; border: 2px solid var(--blood); background: var(--blood); transform: rotate(45deg); }
  .rp-label { font-family: 'IBM Plex Mono', monospace; font-size: .5rem; letter-spacing: .18em; text-transform: uppercase; color: rgba(255,255,255,.4); margin-bottom: .4rem; }
  .rp-title { font-family: 'Barlow Condensed', sans-serif; font-size: 1.3rem; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: #fff; margin-bottom: .9rem; }
  .rp-tasks { display: flex; flex-direction: column; gap: .4rem; }
  .rp-task { display: flex; align-items: baseline; gap: .7rem; font-size: .82rem; color: rgba(255,255,255,.4); line-height: 1.65; }
  .rp-task::before { content: '—'; color: rgba(255,255,255,.2); flex-shrink: 0; }
  .rp-done { color: rgba(150,200,130,.7); }
  .rp-done::before { content: '✓'; color: rgba(150,200,130,.7); }

  </style>

  <script is:inline>
    // Filter analyses
    window.filterAnalyses = function(theme, btn) {
      document.querySelectorAll('.af-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      document.querySelectorAll('.a-card').forEach(card => {
        if (theme === 'all' || card.dataset.theme === theme) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
          card.classList.remove('open');
        }
      });
    };

    // Toggle analysis card
    window.toggleCard = function(card) {
      card.classList.toggle('open');
    };

    // Toggle architecture detail
    window.toggleArchi = function(cell, detailId) {
      // Close all other details
      document.querySelectorAll('.archi-detail').forEach(d => {
        if (d.id !== detailId) { d.classList.remove('visible'); }
      });
      document.querySelectorAll('.archi-cell').forEach(c => {
        if (c !== cell) { c.classList.remove('open'); }
      });
      const detail = document.getElementById(detailId);
      if (!detail) return;
      const isOpen = detail.classList.contains('visible');
      detail.classList.toggle('visible');
      cell.classList.toggle('open');
      if (!isOpen) {
        const grid = document.getElementById('archi-grid');
        grid.parentNode.insertBefore(detail, grid.nextSibling);
      }
    };

    // Timeline animation
    window.addEventListener('load', () => {
      const tls = document.querySelectorAll('.tl-item');
      const obs = new IntersectionObserver(entries => {
        entries.forEach(e => {
          if (e.isIntersecting) e.target.classList.add('tl-visible');
        });
      }, { threshold: 0.15 });
      tls.forEach(el => obs.observe(el));
    });

    // Accordion (standard from layout)
    window.toggleAcc = function(head) {
      const item = head.parentElement;
      item.classList.toggle('open');
    };

    // Sidebar scroll highlighting
    window.addEventListener('scroll', () => {
      const sections = document.querySelectorAll('section[id]');
      const links = document.querySelectorAll('.snav-a');
      let current = '';
      sections.forEach(s => {
        if (window.scrollY >= s.offsetTop - 120) current = s.id;
      });
      links.forEach(l => {
        l.classList.remove('on');
        if (l.getAttribute('href') === '#' + current) l.classList.add('on');
      });
    });
  </script>

</FicheLayout>
