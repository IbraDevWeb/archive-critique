  <style is:global>
  /* ═══════════════════════════════════════════
     DESIGN SYSTEM — Parchemin & Lapis-lazuli
     Palette : sable / terracotta / lapis / or
     ═══════════════════════════════════════════ */
  :root {
    --parch:  #f5f0e8;
    --parch2: #ede6d8;
    --parch3: #e0d6c2;
    --ink:    #1a140c;
    --ink2:   #251c10;
