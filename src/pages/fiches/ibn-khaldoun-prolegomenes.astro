    background-image:
      linear-gradient(30deg,rgba(200,144,10,.04) 1px,transparent 1px),
      linear-gradient(-30deg,rgba(200,144,10,.04) 1px,transparent 1px),
      linear-gradient(rgba(255,255,255,.015) 1px,transparent 1px),
      linear-gradient(90deg,rgba(255,255,255,.015) 1px,transparent 1px);
    background-size:40px 40px,40px 40px,80px 80px,80px 80px;
    pointer-events:none;
  }

  .hero-diag{
    position:absolute;bottom:0;right:0;
    width:42%;height:100%;
    background:var(--lapis2);
    clip-path:polygon(35% 0,100% 0,100% 100%,0% 100%);
    opacity:.11;pointer-events:none;
  }

  /* Ornement hexagonal */
  .hero-hex{
    position:absolute;right:8%;top:15%;
    width:180px;height:180px;
    border:1px solid rgba(200,144,10,.12);
    transform:rotate(30deg);
    pointer-events:none;
  }
  .hero-hex::after{
    content:'';position:absolute;inset:15px;
    border:1px solid rgba(200,144,10,.08);
  }

  .hero-strate{
    position:absolute;bottom:0;left:0;right:0;
    height:5px;
    background:linear-gradient(90deg,var(--terra),var(--gold),var(--lapis),var(--gold),var(--terra));
    opacity:.7;
  }

  .hero-tag{
    font-family:'IBM Plex Mono',monospace;
    font-size:.58rem;letter-spacing:.28em;text-transform:uppercase;
    color:var(--gold);margin-bottom:2.5rem;
    opacity:0;animation:fadeUp .7s ease forwards .1s;
  }

  .hero-h1{
    font-family:'Barlow Condensed',sans-serif;
    font-size:clamp(3.5rem,7vw,9rem);
    font-weight:900;line-height:.88;
    letter-spacing:-.01em;text-transform:uppercase;
    opacity:0;animation:fadeUp .9s ease forwards .25s;
  }

  .hero-h1 .line-pre{display:block;color:rgba(255,255,255,.28);font-size:.38em;letter-spacing:.14em;font-weight:400;margin-bottom:.5rem;}
  .hero-h1 .line1{display:block;color:#fff;}
  .hero-h1 .line2{display:block;color:var(--gold);}

  .hero-rule{
    width:120px;height:3px;
    background:linear-gradient(90deg,var(--terra),var(--gold));
    margin:2.5rem 0 2rem;
    opacity:0;animation:fadeUp .7s ease forwards .5s;
  }

  .hero-sub{
    max-width:680px;
    font-size:1.04rem;font-weight:400;font-style:italic;
    color:rgba(255,255,255,.58);line-height:1.88;
    opacity:0;animation:fadeUp .8s ease forwards .4s;
  }
  .hero-sub strong{color:#fff;font-style:normal;}

  .hero-chips{
    display:flex;flex-wrap:wrap;gap:.6rem;
    margin-top:2rem;
    opacity:0;animation:fadeUp .7s ease forwards .7s;
  }

  .chip{
    font-family:'IBM Plex Mono',monospace;
    font-size:.55rem;letter-spacing:.12em;text-transform:uppercase;
    padding:.28rem .8rem;border:1px solid;
  }
  .chip-terra{color:var(--terra);border-color:rgba(181,74,26,.4);background:rgba(181,74,26,.08);}
  .chip-gold {color:var(--gold); border-color:rgba(200,144,10,.4); background:rgba(200,144,10,.08);}
  .chip-lapis{color:#7aaad4;    border-color:rgba(28,74,138,.4);  background:rgba(28,74,138,.08);}

  .hero-bottom{
    display:flex;justify-content:space-between;align-items:flex-end;
    padding-top:3rem;border-top:1px solid rgba(255,255,255,.07);
    opacity:0;animation:fadeUp .7s ease forwards .9s;
  }

  .hb-label{
    font-family:'IBM Plex Mono',monospace;
    font-size:.5rem;letter-spacing:.2em;text-transform:uppercase;
    color:rgba(255,255,255,.25);margin-bottom:.4rem;
  }
  .hb-names{
    font-family:'Barlow Condensed',sans-serif;
    font-size:1.6rem;font-weight:700;letter-spacing:.04em;
    text-transform:uppercase;color:#fff;line-height:1.1;
  }
  .hb-names span{color:var(--gold);}

  .hero-thesis{
    text-align:right;max-width:420px;
    font-family:'Lora',serif;
    font-style:italic;font-size:.92rem;
    color:rgba(255,255,255,.42);line-height:1.72;
  }
  .hero-thesis cite{
    display:block;margin-top:.5rem;
    font-style:normal;font-family:'IBM Plex Mono',monospace;
    font-size:.5rem;letter-spacing:.15em;text-transform:uppercase;
    color:var(--gold);
  }

  /* ═══ GENERIC SECTION ═══ */
  .sec{padding:5.5rem 6rem;border-bottom:1px solid var(--rule);}
  .sec.alt{background:var(--parch2);}
  .sec.dark{background:var(--ink2);color:#fff;}
  .sec.lapis{background:var(--lapis2);color:#fff;}
  .sec.terra{background:var(--terra2);color:#fff;}
  .sec.sand{background:#2a1e10;color:#fff;}

  .sec-eyebrow{display:flex;align-items:center;gap:1.2rem;margin-bottom:3rem;}

  .sec-num{
    font-family:'IBM Plex Mono',monospace;
    font-size:.52rem;letter-spacing:.2em;text-transform:uppercase;
    color:var(--gold2);background:var(--gold-pale);
    padding:.28rem .75rem;
  }
  .dark .sec-num,.lapis .sec-num,.terra .sec-num,.sand .sec-num{
    background:rgba(200,144,10,.2);color:#f0c870;
  }

  .sec-h2{
    font-family:'Barlow Condensed',sans-serif;
    font-size:2.6rem;font-weight:800;
    letter-spacing:.01em;text-transform:uppercase;line-height:1;
  }
  .sec-h2 em{color:var(--terra);font-style:normal;}
  .dark .sec-h2,.lapis .sec-h2,.terra .sec-h2,.sand .sec-h2{color:#fff;}
  .dark .sec-h2 em,.sand .sec-h2 em{color:var(--gold);}
  .lapis .sec-h2 em{color:#f0c870;}

  /* ═══ CONCEPT CARDS ═══ */
  .concept-grid{
    display:grid;grid-template-columns:repeat(3,1fr);
    gap:2px;background:var(--ink);
    border:1px solid var(--ink);
    margin-top:1rem;
  }
  .concept-card{
    background:var(--parch);
    padding:2.2rem;
    position:relative;overflow:hidden;
    cursor:pointer;
    transition:background .3s;
  }
  .alt .concept-card{background:var(--parch2);}

  .concept-card::after{
    content:attr(data-num);
    position:absolute;right:.8rem;bottom:-1rem;
    font-family:'Barlow Condensed',sans-serif;
    font-size:7rem;font-weight:900;
    color:rgba(0,0,0,.04);line-height:1;
    pointer-events:none;
  }

  /* Ornement géométrique sur les cartes */
  .concept-card::before{
    content:'';
    position:absolute;top:10px;right:10px;
    width:20px;height:20px;
    border:1px solid rgba(200,144,10,.18);
    transform:rotate(45deg);
    pointer-events:none;
  }

  .cc-tag{
    font-family:'IBM Plex Mono',monospace;
    font-size:.5rem;letter-spacing:.2em;text-transform:uppercase;
    color:var(--terra);display:block;margin-bottom:.5rem;
  }
  .cc-title{
    font-family:'Barlow Condensed',sans-serif;
    font-size:1.45rem;font-weight:800;
    letter-spacing:.02em;text-transform:uppercase;
    line-height:1.1;margin-bottom:.6rem;
  }
  .cc-arabic{
    font-family:'Lora',serif;
    font-style:italic;font-size:.82rem;
    color:var(--gold2);margin-bottom:.7rem;
    letter-spacing:.04em;
  }
  .cc-short{font-size:.88rem;color:var(--dust);line-height:1.72;}
  .cc-expand{
    max-height:0;overflow:hidden;
    transition:max-height .5s cubic-bezier(.16,1,.3,1),opacity .4s ease,padding .4s ease;
    opacity:0;
  }
  .cc-expand.open{max-height:600px;opacity:1;padding-top:1rem;}
  .cc-expand-body{
    font-size:.85rem;color:var(--ink);line-height:1.82;
    border-top:1px solid var(--rule);padding-top:1rem;
  }
  .cc-expand-body p{margin-bottom:.7rem;}
  .cc-expand-body p:last-child{margin-bottom:0;}
  .cc-expand-body strong{color:var(--terra);font-weight:600;}
  .cc-today{
    margin-top:.8rem;padding:.8rem 1rem;
    background:var(--gold-pale);
    border-left:2px solid var(--gold);
    font-size:.8rem;font-style:italic;
    color:var(--ink2);line-height:1.6;
  }
  .cc-today::before{
    content:'Postérité → ';
    font-style:normal;font-family:'IBM Plex Mono',monospace;
    font-size:.48rem;letter-spacing:.12em;text-transform:uppercase;
    color:var(--gold2);display:block;margin-bottom:.2rem;
  }
  .cc-toggle{
    display:flex;align-items:center;gap:.5rem;
    margin-top:1rem;
    font-family:'IBM Plex Mono',monospace;
    font-size:.52rem;letter-spacing:.12em;text-transform:uppercase;
    color:var(--terra);cursor:pointer;
    transition:color .2s;
  }
  .cc-arrow{
    width:16px;height:16px;border:1px solid var(--terra);
    display:flex;align-items:center;justify-content:center;
    font-size:.7rem;transition:transform .3s;
  }
  .open-arrow .cc-arrow{transform:rotate(180deg);}
  .concept-card:hover{background:var(--terra-pale);}

  /* ═══ ACCORDION ═══ */
  .accordion{margin-top:1.5rem;}
  .acc-item{border-bottom:1px solid var(--rule);overflow:hidden;}
  .dark .acc-item,.lapis .acc-item,.terra .acc-item,.sand .acc-item{border-color:rgba(255,255,255,.08);}
  .acc-head{
    display:flex;align-items:center;justify-content:space-between;
    padding:1.4rem 0;cursor:pointer;
    transition:color .2s;user-select:none;
  }
  .acc-head:hover .acc-title{color:var(--terra);}
  .dark .acc-head:hover .acc-title,.lapis .acc-head:hover .acc-title,.sand .acc-head:hover .acc-title{color:var(--gold);}
  .acc-title{
    font-family:'Barlow Condensed',sans-serif;
    font-size:1.1rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;
    transition:color .2s;
  }
  .dark .acc-title,.lapis .acc-title,.terra .acc-title,.sand .acc-title{color:#fff;}
  .acc-icon{
    width:28px;height:28px;border:1px solid var(--rule);
    display:flex;align-items:center;justify-content:center;
    flex-shrink:0;transition:all .3s;
    font-family:'Barlow Condensed',sans-serif;font-size:1.2rem;
    color:var(--terra);
  }
  .dark .acc-icon,.lapis .acc-icon,.terra .acc-icon,.sand .acc-icon{border-color:rgba(255,255,255,.12);color:var(--gold);}
  .acc-item.open .acc-icon{transform:rotate(45deg);background:var(--terra);color:#fff;border-color:var(--terra);}
  .dark .acc-item.open .acc-icon,.lapis .acc-item.open .acc-icon,.sand .acc-item.open .acc-icon{background:var(--gold);color:var(--ink);border-color:var(--gold);}
  .acc-body{max-height:0;overflow:hidden;transition:max-height .5s cubic-bezier(.16,1,.3,1);}
  .acc-item.open .acc-body{max-height:1200px;}
  .acc-inner{padding:0 0 2rem;font-size:.9rem;color:#3a3028;line-height:1.88;}
  .dark .acc-inner,.lapis .acc-inner,.terra .acc-inner,.sand .acc-inner{color:rgba(255,255,255,.65);}
  .acc-inner p{margin-bottom:.9rem;}
  .acc-inner p:last-child{margin-bottom:0;}
  .acc-inner strong{color:var(--ink);font-weight:600;}
  .dark .acc-inner strong,.lapis .acc-inner strong,.sand .acc-inner strong{color:#fff;}
  .acc-inner em{font-style:italic;color:var(--terra);}
  .dark .acc-inner em,.lapis .acc-inner em,.sand .acc-inner em{color:var(--gold);}

  /* ═══ PULL QUOTES ═══ */
  .pq{padding:3rem 4rem;margin:3rem 0;position:relative;overflow:hidden;}
  .pq.terra{background:var(--terra2);color:#fff;}
  .pq.lapis{background:var(--lapis2);color:#fff;}
  .pq.sand{background:var(--ink2);color:#fff;border-left:4px solid var(--gold);}
  .pq::before{
    content:'\201C';
    position:absolute;top:-2rem;left:2rem;
    font-family:'Lora',serif;
    font-size:14rem;line-height:1;opacity:.08;
    pointer-events:none;color:#fff;
  }
  .pq p{font-family:'Lora',serif;font-size:1.35rem;font-style:italic;font-weight:400;line-height:1.68;position:relative;z-index:1;}
  .pq cite{
    display:block;margin-top:1.2rem;
    font-family:'IBM Plex Mono',monospace;
    font-size:.55rem;letter-spacing:.15em;text-transform:uppercase;
    font-style:normal;color:rgba(255,255,255,.4);
  }
  .pq.sand cite{color:var(--gold);}

  /* ═══ CYCLE DIAGRAM ═══ */
  .cycle-wrap{background:var(--ink);border:1px solid rgba(255,255,255,.06);padding:2.5rem;margin-top:2rem;}

  /* ═══ COMPARISON TABLE ═══ */
  .compare-sec{margin-top:2rem;}
  .compare-row{
    display:grid;grid-template-columns:1fr 80px 1fr;
    gap:1rem;align-items:center;
    padding:1rem 0;border-bottom:1px solid var(--rule);
  }
  .cr-label-l,.cr-label-r{font-size:.88rem;color:#3a3028;line-height:1.55;}
  .cr-label-r{text-align:right;}
  .cr-mid{
    font-family:'IBM Plex Mono',monospace;
    font-size:.52rem;letter-spacing:.1em;text-transform:uppercase;
    color:var(--dust);text-align:center;line-height:1.3;
  }
  .compare-header{
    display:grid;grid-template-columns:1fr 80px 1fr;
    gap:1rem;padding-bottom:1rem;
    border-bottom:2px solid var(--rule);margin-bottom:.5rem;
  }
  .ch-title{font-family:'Barlow Condensed',sans-serif;font-size:.9rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;}
  .ch-title.terra{color:var(--terra);}
  .ch-title.lapis{color:var(--lapis);text-align:right;}

  /* ═══ GLOSSAIRE ═══ */
  .glos-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px;background:var(--rule);border:1px solid var(--rule);}
  .gi{background:var(--parch);padding:2rem 2.5rem;position:relative;overflow:hidden;transition:background .3s;}
  .alt .gi{background:var(--parch2);}
  .gi:hover{background:var(--gold-pale);}
  .gi::after{
    content:attr(data-g);
    position:absolute;right:1rem;bottom:-1rem;
    font-family:'Barlow Condensed',sans-serif;
    font-size:8rem;font-weight:900;color:rgba(0,0,0,.04);
    line-height:1;pointer-events:none;
  }
  .gi-src{
    font-family:'IBM Plex Mono',monospace;
    font-size:.5rem;letter-spacing:.2em;text-transform:uppercase;
    color:var(--terra);display:block;margin-bottom:.3rem;
  }
  .gi-term{
    font-family:'Barlow Condensed',sans-serif;
    font-size:1.55rem;font-weight:800;letter-spacing:.02em;
    text-transform:uppercase;margin-bottom:.3rem;line-height:1.1;
  }
  .gi-arabic{
    font-family:'Lora',serif;font-style:italic;
    font-size:.85rem;color:var(--gold2);margin-bottom:.6rem;
  }
  .gi-def{font-size:.88rem;color:#3a3028;line-height:1.78;margin-bottom:.7rem;}
  .gi-now{
    padding:.65rem 1rem;
    background:rgba(200,144,10,.1);
    border-left:2px solid var(--gold);
    font-style:italic;font-size:.8rem;color:var(--ink2);line-height:1.6;
  }
  .gi-now::before{
    content:'Enjeu → ';
    font-style:normal;font-family:'IBM Plex Mono',monospace;
    font-size:.48rem;letter-spacing:.12em;text-transform:uppercase;
    color:var(--gold2);display:block;margin-bottom:.2rem;
  }

  /* ═══ TIMELINE ═══ */
  .timeline-container{position:relative;padding-left:3rem;margin-top:2rem;}
  .timeline-container::before{
    content:'';position:absolute;left:14px;top:0;bottom:0;width:2px;
    background:linear-gradient(to bottom,var(--terra),var(--gold),var(--lapis));
  }
  .tl-item{
    position:relative;margin-bottom:2.5rem;
    opacity:0;transform:translateX(-20px);
    transition:opacity .6s ease,transform .6s ease;
  }
  .tl-item.tl-visible{opacity:1;transform:none;}
  .tl-dot{
    position:absolute;left:-2.75rem;top:.35rem;
    width:16px;height:16px;
    border:2px solid;background:var(--parch);
    transform:rotate(45deg);
    transition:transform .3s,background .3s;
  }
  .alt .tl-dot{background:var(--parch2);}
  .tl-item:hover .tl-dot{transform:rotate(45deg) scale(1.4);background:var(--gold);}
  .tl-dot.terra{border-color:var(--terra);}
  .tl-dot.gold {border-color:var(--gold);}
  .tl-dot.lapis{border-color:var(--lapis);}
  .tl-year{font-family:'IBM Plex Mono',monospace;font-size:.58rem;letter-spacing:.12em;text-transform:uppercase;color:var(--dust);margin-bottom:.3rem;}
  .tl-title{font-family:'Barlow Condensed',sans-serif;font-size:1.15rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;margin-bottom:.4rem;}
  .tl-body{font-size:.88rem;color:var(--dust);line-height:1.78;}
  .tl-body strong{color:var(--ink);font-weight:600;}

  /* ═══ STRATE INDICATOR ═══ */
  .strates-row{display:flex;gap:0;margin-top:1.5rem;border:1px solid var(--rule);overflow:hidden;}
  .strate{
    flex:1;padding:1.2rem 1.5rem;
    position:relative;border-right:1px solid var(--rule);
    transition:background .3s;
  }
  .strate:last-child{border-right:none;}
  .strate:hover{background:var(--gold-pale);}
  .strate-label{font-family:'IBM Plex Mono',monospace;font-size:.48rem;letter-spacing:.18em;text-transform:uppercase;color:var(--dust);margin-bottom:.4rem;}
  .strate-name{font-family:'Barlow Condensed',sans-serif;font-size:1rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:var(--ink);line-height:1.2;}
  .strate-color{position:absolute;bottom:0;left:0;right:0;height:3px;}

  /* ═══ QUIZ ═══ */
  .quiz-wrap{background:var(--ink);color:#fff;padding:4rem 5rem;margin-top:2rem;position:relative;overflow:hidden;}
  .quiz-wrap::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--terra),var(--gold),var(--lapis),var(--gold));}
  .quiz-title{font-family:'Barlow Condensed',sans-serif;font-size:1.1rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--gold);margin-bottom:.4rem;}
  .quiz-meta{font-family:'IBM Plex Mono',monospace;font-size:.5rem;letter-spacing:.15em;text-transform:uppercase;color:rgba(255,255,255,.25);margin-bottom:2rem;}
  .quiz-progress-bar{height:3px;background:rgba(255,255,255,.1);border-radius:2px;margin-bottom:2.5rem;overflow:hidden;}
  .quiz-progress-fill{height:100%;background:var(--gold);transition:width .5s ease;}
  .quiz-question{font-family:'Lora',serif;font-size:1.2rem;font-style:italic;color:#fff;line-height:1.62;margin-bottom:2rem;}
  .quiz-options{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
  .qopt{
    padding:1.2rem 1.5rem;
    border:1px solid rgba(255,255,255,.12);
    background:rgba(255,255,255,.02);
    cursor:pointer;
    font-family:'Barlow Condensed',sans-serif;
    font-size:.92rem;font-weight:500;letter-spacing:.04em;
    color:rgba(255,255,255,.7);text-transform:uppercase;
    transition:all .2s;text-align:left;position:relative;overflow:hidden;
  }
  .qopt::before{content:'';position:absolute;inset:0;background:var(--terra2);transform:scaleX(0);transform-origin:left;transition:transform .3s ease;z-index:0;}
  .qopt:hover{color:#fff;border-color:var(--terra);}
  .qopt:hover::before{transform:scaleX(1);}
  .qopt span{position:relative;z-index:1;}
  .qopt.correct{background:rgba(30,100,170,.3);border-color:var(--lapis);color:#9abfe8;}
  .qopt.wrong  {background:rgba(181,74,26,.3);border-color:var(--terra);color:#f0a880;}
  .qopt.reveal {background:rgba(30,100,170,.15);border-color:var(--lapis);color:#9abfe8;}
  .quiz-feedback{margin-top:1.5rem;padding:1.2rem 1.5rem;background:rgba(255,255,255,.04);border-left:3px solid var(--gold);font-size:.9rem;color:rgba(255,255,255,.7);line-height:1.72;display:none;}
  .quiz-feedback.show{display:block;}
  .quiz-nav{display:flex;justify-content:space-between;align-items:center;margin-top:2rem;}
  .quiz-btn{font-family:'Barlow Condensed',sans-serif;font-size:.8rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;padding:.7rem 2rem;border:none;background:var(--terra2);color:#fff;cursor:pointer;transition:background .2s;}
  .quiz-btn:hover{background:var(--terra);}
  .quiz-btn:disabled{opacity:.3;cursor:not-allowed;}
  .quiz-counter{font-family:'IBM Plex Mono',monospace;font-size:.6rem;letter-spacing:.15em;color:rgba(255,255,255,.3);}
  .quiz-status{font-family:'IBM Plex Mono',monospace;font-size:.6rem;letter-spacing:.12em;color:rgba(255,255,255,.35);}

  /* ═══ RÉFLEXION ═══ */
  .qstack{display:flex;flex-direction:column;gap:2px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.05);margin-top:1.5rem;}
  .qi{
    background:rgba(255,255,255,.02);padding:2rem 2.5rem;
    display:grid;grid-template-columns:60px 1fr;
    gap:1.5rem;align-items:start;
    transition:background .3s;border-left:3px solid transparent;
  }
  .qi:hover{background:rgba(200,144,10,.06);border-left-color:var(--gold);}
  .qi-n{font-family:'IBM Plex Mono',monospace;font-size:.55rem;letter-spacing:.15em;text-transform:uppercase;color:var(--gold);padding-top:.2rem;}
  .qi-t{font-family:'Lora',serif;font-size:1.05rem;font-style:italic;color:#fff;line-height:1.72;margin-bottom:.5rem;}
  .qi-hint{font-family:'IBM Plex Mono',monospace;font-size:.58rem;color:rgba(255,255,255,.28);line-height:1.65;}
  .qi-tags{display:flex;flex-wrap:wrap;gap:.4rem;margin-top:.7rem;}
  .qi-tag{font-family:'IBM Plex Mono',monospace;font-size:.48rem;letter-spacing:.1em;text-transform:uppercase;border:1px solid rgba(200,144,10,.3);color:var(--gold);padding:.18rem .55rem;}

  /* ═══ MODAL ═══ */
  .modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:2000;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .3s;}
  .modal-overlay.show{opacity:1;pointer-events:all;}
  .modal{background:var(--ink2);color:#fff;padding:4rem;max-width:560px;width:90%;position:relative;border-top:4px solid var(--gold);}
  .modal-title{font-family:'Barlow Condensed',sans-serif;font-size:2.5rem;font-weight:900;text-transform:uppercase;letter-spacing:.04em;margin-bottom:.5rem;}
  .modal-score{font-family:'Barlow Condensed',sans-serif;font-size:5rem;font-weight:900;color:var(--gold);line-height:1;margin:1.5rem 0;}
  .modal-msg{font-style:italic;color:rgba(255,255,255,.6);line-height:1.72;margin-bottom:2rem;}
  .modal-close{font-family:'Barlow Condensed',sans-serif;font-size:.8rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;padding:.7rem 2rem;border:none;background:var(--terra2);color:#fff;cursor:pointer;}

  /* ═══ ANIMATIONS ═══ */
  @keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:none}}

  /* ═══ RESPONSIVE ═══ */
  @media(max-width:900px){
    :root{--sidebar:0px}
    .snav{display:none}.main{margin-left:0}
    .hero{padding:3rem 2rem 3rem}.sec{padding:3.5rem 2rem}
    .concept-grid{grid-template-columns:1fr}.glos-grid{grid-template-columns:1fr}
    .quiz-options{grid-template-columns:1fr}.pq{padding:2rem}
    .compare-row{grid-template-columns:1fr}.cr-label-r{text-align:left}.cr-mid{display:none}
  }
  </style>

  <script>
  /* ─── CURSOR ─── */
  const cur = document.getElementById('cur');
  if (cur) {
    document.addEventListener('mousemove', e => { 
      cur.style.left = e.clientX + 'px'; 
      cur.style.top = e.clientY + 'px'; 
    });
    document.addEventListener('mouseover', e => {
      const target = e.target as HTMLElement;
      if (target && target.closest('a,button,.concept-card,.qopt,.acc-head,.gi,.qi')) cur.classList.add('expand');
      else cur.classList.remove('expand');
    });
  }

  /* ─── PROGRESS ─── */
  const prog = document.getElementById('prog');
  if (prog) {
    window.addEventListener('scroll', () => {
      const max = document.body.scrollHeight - window.innerHeight;
      prog.style.transform = `scaleX(${window.scrollY / max})`;
    });
  }

  /* ─── TIMELINE ─── */
  const tlObs = new IntersectionObserver(entries => {
    entries.forEach((e, i) => { 
      if (e.isIntersecting) setTimeout(() => e.target.classList.add('tl-visible'), i * 120); 
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.tl-item').forEach(el => tlObs.observe(el));

  /* ─── ACTIVE NAV ─── */
  const navo = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        document.querySelectorAll('.snav-a').forEach(l => l.classList.remove('on'));
        const a = document.querySelector(`.snav-a[href="#${e.target.id}"]`);
        if (a) a.classList.add('on');
      }
    });
  }, { threshold: 0.3 });
  document.querySelectorAll('section[id]').forEach(s => navo.observe(s));

  /* ─── ACCORDION ─── */
  window.toggleAcc = function(head: HTMLElement) {
    const item = head.parentElement;
    if (!item) return;
    const wasOpen = item.classList.contains('open');
    if (item.parentElement) {
      item.parentElement.querySelectorAll('.acc-item.open').forEach(i => i.classList.remove('open'));
    }
    if (!wasOpen) item.classList.add('open');
  }

  /* ─── CONCEPT CARDS ─── */
  let openedConcepts = new Set();
  window.toggleCard = function(card: HTMLElement) {
    const expand = card.querySelector('.cc-expand');
    const toggle = card.querySelector('.cc-toggle');
    const num = card.dataset.num;
    
    if (!expand || !toggle) return;
    
    const isOpen = expand.classList.contains('open');
    expand.classList.toggle('open', !isOpen);
    toggle.classList.toggle('open-arrow', !isOpen);
    
    const label = toggle.querySelector('span:last-child');
    if (label) label.textContent = isOpen ? 'Lire l\'analyse' : 'Réduire';
    
    if (!isOpen && num) {
      openedConcepts.add(num);
      updateConceptCount();
    }
  }
  
  function updateConceptCount() {
    const count = openedConcepts.size;
    const conceptCount = document.getElementById('conceptCount');
    const conceptFill = document.getElementById('conceptFill');
    if (conceptCount) conceptCount.textContent = `${count}/6`;
    if (conceptFill) conceptFill.style.width = `${(count / 6) * 100}%`;
  }

  /* ─── QUIZ ─── */
  // The correct answers have been shuffled to vary their index positions
  const quizData = [
    {
      q: "Selon Ibn Khaldoun, l''asabiyya est avant tout :",
      opts:[
        "L'obéissance hiérarchique des sujets envers leur souverain",
        "La solidarité de groupe qui permet à une communauté de conquérir et de maintenir le pouvoir politique",
        "La fierté ethnique des tribus arabes fondée sur la pureté de la race",
        "Un sentiment religieux commun partagé par les membres d'une même confession"
      ],
      correct: 1,
      feedback:"Exact. L''asabiyya est la solidarité organique d'un groupe — fondée sur les liens de sang, tribaux, ou un projet commun (souvent religieux). C'est la force motrice de toute dynamique politique dans les Prolégomènes. Elle permet la conquête, fonde les dynasties, puis s'étiole avec le luxe et la sédentarisation."
    },
    {
      q: "La théorie du cycle dynastique d'Ibn Khaldoun affirme que :",
      opts:[
        "La durée d'une dynastie dépend avant tout de la qualité de ses institutions juridiques",
        "Les dynasties les plus puissantes peuvent durer indéfiniment si elles maintiennent leurs armées",
        "Toute dynastie traverse environ trois à quatre générations avant de décliner et d'être remplacée",
        "Seules les dynasties fondées sur la religion islamique sont stables et durables"
      ],
      correct: 2,
      feedback:"Précisément. C'est l'une des propositions les plus originales des Prolégomènes. Ibn Khaldoun chiffre le cycle à 3–4 générations (~120 ans). La 1ère génération conquiert, la 2ème consolide, la 3ème jouit et la 4ème décline — parce que l''asabiyya s'érode à mesure que la vie sédentaire et le luxe dissolvent la solidarité fondatrice."
    },
    {
      q: "La dialectique badāwa / ḥaḍāra chez Ibn Khaldoun signifie que :",
      opts:[
        "Les deux modes de vie se succèdent cycliquement : la vitalité nomade produit des dynasties qui se sédentarisent, se corrompent et sont renversées par une nouvelle vague nomade",
        "La vie nomade est moralement supérieure à la vie sédentaire",
        "La vie sédentaire est le stade naturel et définitif de l'évolution humaine",
        "Les nomades et les sédentaires forment deux races naturellement différentes"
      ],
      correct: 0,
      feedback:"Exactement. C'est la structure dialectique fondamentale des Prolégomènes. Ibn Khaldoun précise d'ailleurs que les deux modes sont 'également conformes à la nature' — il ne porte pas de jugement moral. Mais il observe que la ḥaḍāra porte en elle le germe de sa propre destruction : le luxe, l'abondance et la dépendance dissolvent l''asabiyya."
    },
    {
      q: "Qu'est-ce qu'Ibn Khaldoun entend par 'ilm al-'umrān (science de la civilisation) ?",
      opts:[
        "Une histoire universelle des peuples islamiques depuis la naissance du Prophète",
        "Une théologie politique qui cherche les causes divines des événements historiques",
        "Un traité de philosophie politique s'inscrivant dans la tradition d'Aristote et d'Al-Farabi",
        "Une discipline nouvelle, autonome, qui a pour objet les lois régulières de la vie sociale humaine — observable, comparable et vérifiable"
      ],
      correct: 3,
      feedback:"Exactement. C'est la revendication la plus audacieuse d'Ibn Khaldoun. Il affirme fonder une science nouvelle, dotée d'un objet propre (la vie sociale organisée), d'une méthode propre (observation, comparaison, critique des sources) et de lois propres (régulières, répétables). Cette revendication est généralement considérée comme la première émergence d'une proto-sociologie dans l'histoire mondiale."
    },
    {
      q: "La théorie économique d'Ibn Khaldoun dans la Section V est remarquable parce qu'elle :",
      opts:[
        "Pose que la richesse est un don divin distribué selon la piété des croyants",
        "Affirme que la valeur de la richesse réside dans le travail humain accumulé — anticipant la théorie de la valeur-travail de 4 siècles",
        "Défend le libre marché contre l'intervention des États et des dynasties",
        "Recommande l'impôt progressif comme instrument de justice sociale"
      ],
      correct: 1,
      feedback:"Parfait. Ibn Khaldoun écrit : 'le gain et la richesse ne sont que la valeur des travaux humains'. Cette affirmation est généralement considérée comme la première formulation claire de la théorie de la valeur-travail — que Adam Smith ne reprendra qu'en 1776 dans La Richesse des Nations et que Marx développera dans Le Capital (1867). Joseph Schumpeter l'a explicitement reconnu comme précurseur."
    },
    {
      q: "En quoi la méthode d'Ibn Khaldoun pour critiquer les sources historiques est-elle innovante ?",
      opts:[
        "Il réclame des sources multiples et indépendantes pour chaque fait historique",
        "Il s'appuie sur les traditions prophétiques (hadiths) pour vérifier les récits historiques",
        "Il confronte les récits aux lois de la société humaine : ce qui est impossible socialement ne peut pas s'être produit, même si des sources respectées l'affirment",
        "Il exige que les historiens aient été témoins oculaires des événements qu'ils rapportent"
      ],
      correct: 2,
      feedback:"Précisément. C'est l'innovation épistémologique majeure de l'Introduction. Ibn Khaldoun donne l'exemple des 600 000 guerriers israélites de Moïse : même si des historiens respectés l'affirment, c'est sociologiquement impossible — un pays de la taille de l'Égypte ne peut nourrir une telle armée. La loi sociale (la taille des empires est proportionnelle à leur base démographique) prime sur le récit. C'est une révolution dans la méthode historique."
    }
  ];

  let currentQ = 0, score = 0, answered = false;

  window.renderQuestion = function() {
    const q = quizData[currentQ];
    
    const qNum = document.getElementById('qNum');
    const qText = document.getElementById('qText');
    const qFeedback = document.getElementById('qFeedback');
    const qNext = document.getElementById('qNext') as HTMLButtonElement;
    const qStatus = document.getElementById('qStatus');
    const quizProgressFill = document.getElementById('quizProgressFill');
    const opts = document.getElementById('qOptions');

    if (qNum) qNum.textContent = String(currentQ + 1);
    if (qText) qText.textContent = q.q;
    if (qFeedback) {
      qFeedback.className = 'quiz-feedback';
      qFeedback.textContent = '';
    }
    if (qNext) qNext.disabled = true;
    if (qStatus) qStatus.textContent = 'Sélectionnez une réponse';
    
    answered = false;
    
    if (quizProgressFill) {
      quizProgressFill.style.width = ((currentQ / quizData.length) * 100) + '%';
    }
    
    if (opts) {
      opts.innerHTML = '';
      q.opts.forEach((opt, i) => {
        const btn = document.createElement('button');
        btn.className = 'qopt';
        btn.innerHTML = `<span>${opt}</span>`;
        btn.onclick = () => window.selectAnswer(i);
        opts.appendChild(btn);
      });
    }
  }

  window.selectAnswer = function(idx: number) {
    if (answered) return;
    answered = true;
    
    const q = quizData[currentQ];
    document.querySelectorAll('.qopt').forEach((o, i) => {
      if (i === q.correct) o.classList.add('correct');
      else if (i === idx && i !== q.correct) o.classList.add('wrong');
      else o.classList.add('reveal');
    });
    
    const fb = document.getElementById('qFeedback');
    if (fb) {
      fb.textContent = q.feedback;
      fb.classList.add('show');
    }
    
    const scoreDisplay = document.getElementById('scoreDisplay');
    const qStatus = document.getElementById('qStatus');
    const qNext = document.getElementById('qNext') as HTMLButtonElement;
    
    if (idx === q.correct) {
      score++;
      if (scoreDisplay) scoreDisplay.textContent = String(score);
      if (qStatus) qStatus.textContent = '✓ Bonne réponse';
    } else {
      if (qStatus) qStatus.textContent = '✗ Réponse incorrecte';
    }
    
    if (qNext) qNext.disabled = false;
    
    const pct = Math.round((score / quizData.length) * 100);
    const sidebarScore = document.getElementById('sidebarScore');
    const sidebarFill = document.getElementById('sidebarFill');
    
    if (sidebarScore) sidebarScore.textContent = `${score}/${quizData.length}`;
    if (sidebarFill) sidebarFill.style.width = pct + '%';
    
    if (currentQ === quizData.length - 1 && qNext) {
      qNext.textContent = 'Voir mon score →';
    }
  }

  window.nextQuestion = function() {
    currentQ++;
    if (currentQ >= quizData.length) { window.showModal(); return; }
    window.renderQuestion();
  }

  window.showModal = function() {
    const msgs = [
      [0, 1, "Prenez le temps de relire la Section II sur l''asabiyya et le cycle dynastique. Le cœur de la théorie reste à découvrir."],
      [2, 3, "Quelques concepts restent flous. Revenez sur la dialectique badāwa/ḥaḍāra et la méthode critique d'Ibn Khaldoun."],
      [4, 4, "Bonne compréhension des grandes lignes. Approfondissez la théorie économique et la notion d''ilm al-'umrān."],
      [5, 5, "Très solide. Vous saisissez bien l'articulation entre 'asabiyya, cycle dynastique et science nouvelle."],
      [6, 6, "Maîtrise remarquable. Vous pouvez désormais mobiliser Ibn Khaldoun dans l'analyse des sociétés contemporaines."]
    ];
    const msg = msgs.find(m => score >= m[0] && score <= (m[1] as number));
    
    const modalScore = document.getElementById('modalScore');
    const modalMsg = document.getElementById('modalMsg');
    const modalOverlay = document.getElementById('modalOverlay');

    if (modalScore) modalScore.textContent = `${score}/6`;
    if (modalMsg) modalMsg.textContent = msg ? String(msg[2]) : '';
    if (modalOverlay) modalOverlay.classList.add('show');
  }

  window.closeModal = function() {
    const modalOverlay = document.getElementById('modalOverlay');
    if (modalOverlay) modalOverlay.classList.remove('show');
    
    currentQ = 0; score = 0; answered = false;
    
    const scoreDisplay = document.getElementById('scoreDisplay');
    const quizProgressFill = document.getElementById('quizProgressFill');
    const qNext = document.getElementById('qNext');
    
    if (scoreDisplay) scoreDisplay.textContent = '0';
    if (quizProgressFill) quizProgressFill.style.width = '0%';
    if (qNext) qNext.textContent = 'Question suivante →';
    
    window.renderQuestion();
  }

  // Initialisation
  window.renderQuestion();
  
  window.addEventListener('load', () => {
    setTimeout(() => {
      const sidebarFill = document.getElementById('sidebarFill');
      const conceptFill = document.getElementById('conceptFill');
      if (sidebarFill) sidebarFill.style.width = '0%';
      if (conceptFill) conceptFill.style.width = '0%';
    }, 500);
  });
  </script>
</FicheLayout>