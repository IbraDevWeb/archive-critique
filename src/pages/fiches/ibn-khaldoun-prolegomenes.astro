    --terra2: #8c3810;
    --terra-pale: #f5e0d4;
    --lapis:  #1c4a8a;
    --lapis2: #143570;
    --lapis-pale: #d8e4f4;
    --gold:   #c8900a;
    --gold2:  #a07208;
    --gold-pale: #faf0d0;
    --dust:   #7a6e60;
    --rule:   #c8bfae;
    --sidebar: 270px;
  }

  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{
    background:var(--parch);
    color:var(--ink);
    font-family:'Lora',serif;
    font-size:17px;
    line-height:1.78;
    overflow-x:hidden;
    cursor:none;
