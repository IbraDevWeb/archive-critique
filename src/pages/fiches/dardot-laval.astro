            <th style="padding:1rem 1.3rem;text-align:left;font-family:'IBM Plex Mono',monospace;font-size:.52rem;letter-spacing:.15em;text-transform:uppercase;border-bottom:2px solid var(--neon);color:var(--dust);background:rgba(232,160,32,.04);">État welfariste (avant)</th>
