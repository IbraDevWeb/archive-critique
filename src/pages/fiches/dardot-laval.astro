---
import FicheLayout from '../../layouts/FicheLayout.astro';

const title = "La Nouvelle Raison du Monde — Dardot & Laval";
const description = "Le néolibéralisme n'est pas une politique économique parmi d'autres. C'est une rationalité globale.";
const fonts = "https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Barlow+Condensed:wght@300;400;500;600;700;800;900&family=IBM+Plex+Mono:ital,wght@0,300;0,400;0,500;1,300&display=swap";
---

<FicheLayout title={title} description={description} fonts={fonts}>
  <div class="modal-overlay" id="modalOverlay">
    <div class="modal">
      <div class="modal-title">Résultat du Quiz</div>
      <div class="modal-score" id="modalScore">0/6</div>
      <p class="modal-msg" id="modalMsg"></p>
      <button class="modal-close" onclick="closeModal()">Fermer et réviser</button>
    </div>
  </div>

  <nav class="snav">
    <div class="snav-brand">
      <div class="snav-kicker">Philosophie politique · 2009</div>
      <div class="snav-title">La Nouvelle<br>Raison du<br>Monde</div>
      <div class="snav-authors">Dardot & Laval</div>
      <div class="snav-year">La Découverte · 2009</div>
    </div>

    <span class="snav-lbl">Introduction</span>
    <a href="#hero" class="snav-a on"><span class="snav-bullet"></span>Présentation</a>
    <a href="#genese" class="snav-a"><span class="snav-bullet"></span>Genèse du néolibéralisme</a>
    <a href="#raison" class="snav-a"><span class="snav-bullet"></span>La raison néolibérale</a>

    <div class="snav-div"></div>
    <span class="snav-lbl">Concepts clés</span>
    <a href="#concepts" class="snav-a"><span class="snav-bullet"></span>Concepts fondamentaux</a>
    <a href="#sujet" class="snav-a"><span class="snav-bullet"></span>La fabrication du sujet</a>
    <a href="#etat" class="snav-a"><span class="snav-bullet"></span>L'État entrepreneur</a>

    <div class="snav-div"></div>
    <span class="snav-lbl">Dialogues</span>
    <a href="#foucault" class="snav-a"><span class="snav-bullet"></span>Dialogue avec Foucault</a>
    <a href="#reseau" class="snav-a"><span class="snav-bullet"></span>Réseau d'auteurs</a>
    <a href="#aujourdhui" class="snav-a"><span class="snav-bullet"></span>Actualité</a>

    <div class="snav-div"></div>
    <span class="snav-lbl">Pédagogie</span>
    <a href="#quiz" class="snav-a"><span class="snav-bullet"></span>⚡ Quiz interactif</a>
    <a href="#reflexion" class="snav-a"><span class="snav-bullet"></span>Pistes de réflexion</a>
    <a href="#synthese" class="snav-a"><span class="snav-bullet"></span>Synthèse critique</a>

