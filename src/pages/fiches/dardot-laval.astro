</style>

  <script>
    // ─── ACCORDION ───
    window.toggleAcc = function(head) {
      const item = head.parentElement;
      const wasOpen = item.classList.contains('open');
      const parent = item.parentElement;
      parent.querySelectorAll('.acc-item.open').forEach(i => i.classList.remove('open'));
      if (!wasOpen) item.classList.add('open');
    }

    // ─── CONCEPT CARDS ───
    let openedConcepts = new Set();

    window.toggleCard = function(card) {
      const expand = card.querySelector('.cc-expand');
      const toggle = card.querySelector('.cc-toggle');
      const num = card.dataset.num;
      const isOpen = expand.classList.contains('open');

      expand.classList.toggle('open', !isOpen);
      toggle.classList.toggle('open-arrow', !isOpen);
      toggle.querySelector('span:last-child').textContent = isOpen ? 'Lire l\'analyse' : 'Réduire';

      if (!isOpen) {
        openedConcepts.add(num);
        updateConceptCount();
      }
    }

    function updateConceptCount() {
      const count = openedConcepts.size;
      const conceptCountEl = document.getElementById('conceptCount');
      const conceptFillEl = document.getElementById('conceptFill');
      if (conceptCountEl) conceptCountEl.textContent = `${count}/6`;
      if (conceptFillEl) conceptFillEl.style.width = `${(count/6)*100}%`;
    }

    // ─── QUIZ INTERACTIF ───
    const quizData = [
      {
        q: "Selon Dardot et Laval, le néolibéralisme est avant tout :",
        opts: [
          "Un retour au libéralisme classique du laissez-faire",
          "Une politique de réduction de la taille de l'État",
          "Une rationalité gouvernementale qui impose la concurrence comme norme universelle",
          "Une idéologie économique défendue par les grandes entreprises"
        ],
        correct: 2,
        feedback: "Correct. La thèse centrale du livre est que le néolibéralisme n'est pas un simple « moins d'État » ni un retour au marché naturel — c'est une rationalité inédite qui impose la concurrence comme norme à la totalité des activités humaines, y compris à l'État lui-même."
      },
      {
        q: "Le concept de « capital humain » (Gary Becker) signifie que :",
        opts: [
          "L'éducation publique doit être financée par l'État",
          "L'individu doit se concevoir comme une entreprise qui investit en lui-même",
          "Les travailleurs sont exploités par leur employeur",
          "La santé est un bien collectif à protéger"
        ],
        correct: 1,
        feedback: "Exact. Gary Becker (École de Chicago) opère une révolution anthropologique : l'individu n'est plus un citoyen ou un sujet de droits — il est son propre capital, son propre investisseur et la source de ses propres revenus. Cette figure est au cœur de la gouvernementalité néolibérale."
      },
      {
        q: "La gouvernementalité néolibérale, selon Dardot et Laval (suivant Foucault), signifie que le pouvoir s'exerce principalement :",
        opts: [
          "Par la loi et la contrainte physique",
          "Par la propagande et la manipulation des opinions",
          "En produisant des subjectivités qui intériorisent la norme concurrentielle",
          "Par la surveillance policière des comportements déviants"
        ],
        correct: 2,
        feedback: "Parfait. La gouvernementalité désigne une forme de pouvoir qui ne contraint pas directement mais produit des individus qui se gouvernent eux-mêmes selon la norme. C'est plus efficace que la contrainte — les individus s'y conforment par désir, pas par peur."
      },
      {
        q: "L'Ordolibéralisme allemand (Eucken, Röpke) se distingue du libéralisme classique en affirmant que :",
        opts: [
          "L'État doit se retirer totalement de l'économie",
          "Le marché est un ordre naturel qui émerge spontanément",
          "L'État doit activement construire et maintenir les conditions de la concurrence",
          "Le capitalisme doit être remplacé par une économie planifiée"
        ],
        correct: 2,
        feedback: "Exact. C'est l'une des découvertes majeures du livre : le néolibéralisme n'est pas un libéralisme du laissez-faire. Il exige un État fort, actif, interventionniste — mais dont toute l'action est orientée vers la production d'un ordre concurrentiel."
      },
      {
        q: "Le « sujet néolibéral » selon Dardot et Laval est caractérisé par :",
        opts: [
          "Une résistance active aux normes capitalistes",
          "Une auto-exploitation libre — il est à la fois son propre patron et son propre employé",
          "Une dépendance passive à l'État providence",
          "Un refus de la logique marchande dans sa vie privée"
        ],
        correct: 1,
        feedback: "Précisément. Le sujet néolibéral est une figure tragique : il s'exploite lui-même librement, sans qu'aucun exploiteur extérieur ne soit identifiable. C'est ce que Han appelle le burn-out — non pas l'épuisement sous la contrainte, mais l'épuisement par excès de conformité à la norme de la performance."
      },
      {
        q: "En quoi la crise financière de 2008 illustre-t-elle la thèse de Dardot et Laval ?",
        opts: [
          "Elle a montré que le néolibéralisme était fondé économiquement",
          "Elle a produit un tournant keynésien durable dans les politiques économiques",
          "La gestion de la crise s'est effectuée selon la rationalité néolibérale — austérité pour les populations, sauvetage des banques",
          "Elle a conduit à la remise en question du libre-échange international"
        ],
        correct: 2,
        feedback: "Exactement. La crise n'a pas produit de rupture de rationalité — elle a été gérée selon les normes néolibérales. Les États ont socialisé les pertes (sauvé les banques) puis imposé l'austérité pour rembourser cette dette. Le néolibéralisme a survécu à sa propre crise, ce qui illustre sa nature de rationalité hégémonique et non de simple politique."
      }
    ];

    let currentQ = 0;
    let score = 0;
    let answered = false;

    window.renderQuestion = function() {
      const q = quizData[currentQ];
      document.getElementById('qNum').textContent = currentQ + 1;
      document.getElementById('qText').textContent = q.q;
      document.getElementById('qFeedback').className = 'quiz-feedback';
      document.getElementById('qFeedback').textContent = '';
      document.getElementById('qNext').disabled = true;
      document.getElementById('qStatus').textContent = 'Sélectionnez une réponse';
      answered = false;

      const prog = (currentQ / quizData.length) * 100;
      document.getElementById('quizProgressFill').style.width = prog + '%';

      const opts = document.getElementById('qOptions');
      opts.innerHTML = '';
      q.opts.forEach((opt, i) => {
        const btn = document.createElement('button');
        btn.className = 'qopt';
        btn.innerHTML = `<span>${opt}</span>`;
        btn.onclick = () => window.selectAnswer(i, btn);
        opts.appendChild(btn);
      });
    }

    window.selectAnswer = function(idx, btn) {
      if (answered) return;
      answered = true;
      const q = quizData[currentQ];
      const opts = document.querySelectorAll('.qopt');

      opts.forEach((o, i) => {
        if (i === q.correct) o.classList.add('correct');
        else if (i === idx && i !== q.correct) o.classList.add('wrong');
        else o.classList.add('reveal');
      });

      const fb = document.getElementById('qFeedback');
      fb.textContent = q.feedback;
      fb.classList.add('show');

      if (idx === q.correct) {
        score++;
        document.getElementById('scoreDisplay').textContent = score;
        document.getElementById('qStatus').textContent = '✓ Bonne réponse';
      } else {
        document.getElementById('qStatus').textContent = '✗ Réponse incorrecte';
      }

      document.getElementById('qNext').disabled = false;

      const pct = Math.round((score / quizData.length) * 100);
      document.getElementById('sidebarScore').textContent = `${score}/${quizData.length}`;
      document.getElementById('sidebarFill').style.width = pct + '%';

      if (currentQ === quizData.length - 1) {
        document.getElementById('qNext').textContent = 'Voir mon score →';
      }
    }

    window.nextQuestion = function() {
      currentQ++;
      if (currentQ >= quizData.length) {
        window.showModal();
        return;
      }
      window.renderQuestion();
    }

    window.showModal = function() {
      const msgs = [
        [0,1, "Relisez attentivement les sections Thèse centrale et Concepts. Le cœur du livre reste à découvrir."],
        [2,3, "Quelques concepts restent flous. Revenez sur la gouvernementalité et le capital humain."],
        [4,4, "Bonne compréhension des grandes lignes. Approfondissez les distinctions conceptuelles."],
        [5,5, "Très solide. Vous saisissez bien l'articulation entre rationalité, sujet et État néolibéral."],
        [6,6, "Maîtrise remarquable. Vous êtes prêt(e) à débattre de ces enjeux avec rigueur et précision."]
      ];
      const msg = msgs.find(m => score >= m[0] && score <= m[1]);
      document.getElementById('modalScore').textContent = `${score}/6`;
      document.getElementById('modalMsg').textContent = msg ? msg[2] : '';
      document.getElementById('modalOverlay').classList.add('show');
    }

    window.closeModal = function() {
      document.getElementById('modalOverlay').classList.remove('show');
      currentQ = 0; score = 0; answered = false;
      document.getElementById('scoreDisplay').textContent = '0';
      document.getElementById('quizProgressFill').style.width = '0%';
      document.getElementById('qNext').textContent = 'Question suivante →';
      window.renderQuestion();
    }

    // Initialize UI
    window.renderQuestion();

    window.addEventListener('load', () => {
      setTimeout(() => {
        const sf = document.getElementById('sidebarFill');
        const cf = document.getElementById('conceptFill');
        if (sf) sf.style.width = '0%';
        if (cf) cf.style.width = '0%';
      }, 500);
    });
  </script>
</FicheLayout>