const description = "Deux cauchemars, deux prophètes, deux diagnostics radicalement différents sur la fin de la liberté humaine.";
const fonts = "https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,700;1,400;1,500;1,700&family=Bebas+Neue&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap";
---

<FicheLayout title={title} description={description} fonts={fonts}>
  <nav class="sidenav">
    <div class="snav-top">
      <div class="snav-eyebrow">Étude comparative · Dystopies</div>
