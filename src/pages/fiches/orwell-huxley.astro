    .ac-flag.dark { background:rgba(0,0,0,0.06); color:var(--mid); }
    .ac-name { font-family:'EB Garamond',serif; font-size:1.5rem; font-weight:700; line-height:1.2; margin-bottom:.3rem; }
    .ac-work { font-family:'Space Mono',monospace; font-size:0.55rem; letter-spacing:.08em; text-transform:uppercase; color:var(--faint); margin-bottom:1rem; }
    .ac-body { font-size:0.88rem; color:#3a3530; line-height:1.75; }
    .ac-connection { margin-top:1rem; padding:.8rem 1rem; border-left:2px solid var(--gold); background:rgba(200,168,75,.06); font-size:0.82rem; font-style:italic; color:var(--mid); line-height:1.6; }

    /* REFLEXIONS */
    .ref-sec { background:var(--void) !important; color:var(--ash); }
    .ref-sec .sec-num { background:rgba(200,168,75,.15); color:var(--gold); }
    .q-stack { display:flex; flex-direction:column; gap:2px; background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.04); }
    .q-item { background:rgba(255,255,255,.015); padding:2.5rem 3rem; display:grid; grid-template-columns:70px 1fr; gap:2rem; align-items:start; transition:background .3s; border-left:3px solid transparent; }
    .q-item:hover { background:rgba(200,168,75,.05); border-left-color:var(--gold); }
    .q-n { font-family:'Space Mono',monospace; font-size:.55rem; letter-spacing:.15em; text-transform:uppercase; color:var(--gold); padding-top:.2rem; }
    .q-t { font-family:'EB Garamond',serif; font-size:1.15rem; font-style:italic; color:var(--ash); line-height:1.7; margin-bottom:.6rem; }
    .q-hint { font-family:'Space Mono',monospace; font-size:.6rem; color:rgba(240,236,227,.3); font-style:normal; line-height:1.7; }
    .q-tags { display:flex; flex-wrap:wrap; gap:.4rem; margin-top:.8rem; }
    .q-tag { font-family:'Space Mono',monospace; font-size:.5rem; letter-spacing:.1em; text-transform:uppercase; border:1px solid rgba(200,168,75,.3); color:var(--gold); padding:.2rem .6rem; border-radius:2px; }

    /* SYNTHESE */
    .synth-sec { background:var(--huxley) !important; color:var(--ash); }
    .synth-sec .sec-num { background:rgba(255,255,255,.1); color:rgba(240,236,227,.8); }
    .synth-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:2rem; margin-top:1rem; }
    .synth-card { background:rgba(0,0,0,.15); padding:2rem; border-top:3px solid rgba(255,255,255,.15); transition:background .3s; }
    .synth-card:hover { background:rgba(0,0,0,.25); }
    .synth-card-title { font-family:'Space Mono',monospace; font-size:.6rem; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:rgba(240,236,227,.6); margin-bottom:.8rem; }
    .synth-card-body { font-size:.95rem; line-height:1.75; color:rgba(240,236,227,.9); }

    /* RESPONSIVE */
    @media(max-width:1100px){
      :root{--sidebar-w:230px}
      .hero, .sec, .split-dark { padding-left:4rem; padding-right:4rem; }
      .synth-grid { grid-template-columns:1fr 1fr; }
    }
    @media(max-width:820px){
      :root{--sidebar-w:0px}
      .hero, .sec, .split-dark { padding: 4rem 2rem; }
      .hero-split { grid-template-columns:1fr; gap:1rem; }
      .hero-vs-col { display:none; }
      .hero-author { text-align:left; }
      .intro-cols, .diag-grid, .glos-grid, .authors-grid, .synth-grid { grid-template-columns:1fr; }
      .compare-table { font-size:.8rem; }
      .compare-table td, .compare-table th { padding:.8rem; }
      .q-item { grid-template-columns:1fr; }
      .hero-bottom { flex-direction:column; align-items:flex-start; gap:2rem; }
    }
/* ─── CORRECTIONS ORWELL & HUXLEY ─── */
  
  /* 1. Animations (Rend le texte visible) */
  @keyframes up { from { opacity: 0; transform: translateY(28px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

  /* 2. Curseur (Géométrie complète) */
  .cur { 
    width: 12px;
    height: 12px; border-radius: 50%; background: var(--gold) !important; 
    position: fixed; top: 0; left: 0; pointer-events: none; z-index: 9999; 
    transform: translate(-50%,-50%);
    /* mix-blend-mode: multiply;  <--- LIGNE À SUPPRIMER */
    transition: width .3s, height .3s, background .3s; 
  }

  /* 3. Footer (Réintégration du style effacé) */
  footer { 
    background: #050505; color: rgba(240,236,227,.2); padding: 4rem 6rem; 
    display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; 
    font-family: 'Space Mono', monospace; font-size: 0.6rem; 
    letter-spacing: 0.1em; text-transform: uppercase; 
  }
  footer .f-center { 
    font-family: 'Bebas Neue', sans-serif; font-size: 2.5rem; 
    letter-spacing: 0.1em; opacity: 0.12; text-align: center; text-transform: none; 
  }
  footer a { color: var(--gold); text-decoration: none; display: block; text-align: right; transition: color .2s; }
  footer a:hover { color: var(--paper); }

