  </style>

  <script>
  /* ─── CURSOR ─── */
  const cur = document.getElementById('cur');
  if (cur) {
    document.addEventListener('mousemove', e => {
      cur.style.left = e.clientX + 'px';
      cur.style.top  = e.clientY + 'px';
    });
    document.addEventListener('mouseover', e => {
      const target = e.target as HTMLElement;
      if (target.matches('a,button,.q-card,.cc,.actor-card')) cur.classList.add('expand');
      else cur.classList.remove('expand');
    });
  }

  /* ─── PROGRESS BAR ─── */
  const prog = document.getElementById('prog');
  if (prog) {
    window.addEventListener('scroll', () => {
      const s = document.documentElement;
      const pct = s.scrollTop / (s.scrollHeight - s.clientHeight);
      prog.style.transform = `scaleX(${pct})`;
    });
  }

  /* ─── ACTIVE NAV ─── */
  const secs  = document.querySelectorAll('section[id]');
  const links = document.querySelectorAll('.snav-a');
  const navo = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        links.forEach(l => l.classList.remove('on'));
        const a = document.querySelector(`.snav-a[href="#${e.target.id}"]`);
        if (a) a.classList.add('on');
      }
    });
  }, { threshold: 0.25 });
  secs.forEach(s => navo.observe(s));

  /* ─── SCROLL REVEALS ─── */
  const reveals = document.querySelectorAll('.reveal');
  const ro = new IntersectionObserver(entries => {
    entries.forEach((e, i) => {
      if (e.isIntersecting) {
        const target = e.target as HTMLElement;
        target.style.transitionDelay = (i % 4) * 0.08 + 's';
        target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });
  reveals.forEach(r => ro.observe(r));

  /* ─── TIMELINE ─── */
  const tlItems = document.querySelectorAll('.tl-item');
  const tlo = new IntersectionObserver(entries => {
    entries.forEach((e, i) => {
      if (e.isIntersecting) {
        setTimeout(() => e.target.classList.add('visible'), i * 120);
      }
    });
  }, { threshold: 0.15 });
  tlItems.forEach(t => tlo.observe(t));

  /* ═══════════════════════════════════════
     20 QUESTIONS DATA
     ═══════════════════════════════════════ */
  const questions20 = [
    { num: 1,  cat: 'cosmo', heresy: true,  title: "L'éternité de l'univers", desc: "Les philosophes affirment que le monde est éternel — sans commencement ni fin. Ghazâlî démontre qu'ils ne peuvent pas prouver cette thèse sans tomber dans des contradictions insurmontables." },
    { num: 2,  cat: 'cosmo', heresy: false, title: "L'incorruptibilité de l'univers dans le futur", desc: "Corollaire de Q.1 : si le monde est éternel dans le passé, il doit l'être aussi dans le futur. Ghazâlî réfute ce dédoublement de l'éternité." },
    { num: 3,  cat: 'theo',  heresy: false, title: "L'incapacité à prouver l'existence du Créateur", desc: "Malgré leurs déclarations, les philosophes ne peuvent pas démontrer l'existence de Dieu selon leurs propres principes philosophiques." },
    { num: 4,  cat: 'theo',  heresy: false, title: "L'incapacité à prouver la causalité divine", desc: "Ils affirment que Dieu est la cause du monde, mais leur système d'émanation nécessaire détruit la notion même de causalité libre." },
    { num: 5,  cat: 'theo',  heresy: false, title: "L'incapacité à prouver l'unicité de Dieu", desc: "Les prémisses des philosophes ne leur permettent pas de démontrer qu'il n'existe qu'un seul Dieu plutôt qu'une pluralité de principes." },
    { num: 6,  cat: 'theo',  heresy: false, title: "La négation des attributs divins", desc: "Avicenne nie les attributs réels de Dieu (savoir, puissance, volonté) pour éviter la multiplicité en Dieu. Ghazâlî réfute cette dépossession divine." },
    { num: 7,  cat: 'theo',  heresy: false, title: "La transcendance divine", desc: "Comment concilier la transcendance absolue de Dieu avec son action dans le monde ? Les philosophes échouent à résoudre cette tension." },
    { num: 8,  cat: 'theo',  heresy: false, title: "L'essence divine", desc: "La question de ce qu'est Dieu en son essence — sujet sur lequel les philosophes prétendent avoir des certitudes que Ghazâlî conteste." },
    { num: 9,  cat: 'theo',  heresy: false, title: "L'incorporalité de Dieu", desc: "Les philosophes nient que Dieu puisse avoir quelque rapport que ce soit avec la corporéité, mais leur démonstration est jugée insuffisante." },
    { num: 10, cat: 'theo',  heresy: false, title: "L'athéisme des philosophes", desc: "En niant les attributs divins et la création libre, les philosophes basculent dans une forme de déisme vide qui revient à l'athéisme pratique." },
    { num: 11, cat: 'gnose', heresy: false, title: "L'omniscience divine (universaux)", desc: "Dieu connaît-il les universaux ? Les philosophes admettent une connaissance universelle, mais cette concession reste insuffisante selon Ghazâlî." },
    { num: 12, cat: 'gnose', heresy: false, title: "La connaissance divine de soi-même", desc: "La connaissance que Dieu a de sa propre essence — question où l'argument des philosophes est jugé circulaire." },
    { num: 13, cat: 'gnose', heresy: true,  title: "Dieu ne connaît pas les particuliers", desc: "Charge d'hérésie : Avicenne soutient que Dieu ne connaît les choses singulières que de manière universelle. Ghazâlî y voit la négation de la Providence." },
    { num: 14, cat: 'sphes', heresy: false, title: "L'animation des sphères célestes", desc: "Les philosophes attribuent des âmes aux sphères célestes qui les meuvent. Ghazâlî conteste les fondements de cette cosmologie animiste." },
    { num: 15, cat: 'sphes', heresy: false, title: "La finalité du mouvement des sphères", desc: "Pourquoi les sphères se meuvent-elles ? La téléologie astronomique des philosophes est mise en cause." },
    { num: 16, cat: 'sphes', heresy: false, title: "La connaissance sublunaire des âmes sphériques", desc: "Les âmes des sphères auraient-elles conscience du monde d'ici-bas ? Ghazâlî démonte cet angélisme cosmologique." },
    { num: 17, cat: 'natur', heresy: true,  title: "La causalité naturelle", desc: "Question capitale : les philosophes affirment un lien nécessaire entre cause et effet dans la nature. Ghazâlî soutient que le feu ne brûle pas par lui-même mais par la volonté de Dieu — thèse occasionnaliste qui préfigure Hume." },
    { num: 18, cat: 'natur', heresy: false, title: "La substantialité spirituelle de l'âme", desc: "L'âme est-elle une substance spirituelle autarcique, indépendante du corps ? Les philosophes l'affirment sans pouvoir le démontrer selon Ghazâlî." },
    { num: 19, cat: 'natur', heresy: false, title: "L'immortalité de l'âme", desc: "Les philosophes soutiennent l'immortalité de l'âme sur des bases rationnelles. Ghazâlî montre que leurs arguments sont insuffisants et contradictoires." },
    { num: 20, cat: 'natur', heresy: true,  title: "La négation de la résurrection corporelle", desc: "Charge d'hérésie : les philosophes nient la résurrection physique et n'admettent qu'une immortalité spirituelle, traitant les descriptions coraniques de métaphores." },
  ];

  /* Render q-grid */
  const qGrid = document.getElementById('qGrid');
  let openedQs = new Set();
  if (qGrid) {
    questions20.forEach(q => {
      const card = document.createElement('div');
      card.className = 'q-card' + (q.heresy ? ' heresy' : '');
      card.dataset.cat = q.cat;
      card.innerHTML = `
        <div class="q-num">${String(q.num).padStart(2,'0')}</div>
        <div class="q-title">${q.title}</div>
        <div class="q-expand" id="qe${q.num}">${q.desc}</div>
        <div class="q-toggle" id="qt${q.num}">▸ Voir l'enjeu</div>
      `;
      card.addEventListener('click', () => {
        const exp = document.getElementById('qe' + q.num);
        const tog = document.getElementById('qt' + q.num);
        if (exp && tog) {
          const isOpen = exp.classList.toggle('open');
          tog.textContent = isOpen ? '▾ Réduire' : '▸ Voir l\'enjeu';
          if (isOpen) {
            openedQs.add(q.num);
            updateConceptCount();
          }
        }
      });
      qGrid.appendChild(card);
    });
  }

  /* ═══════════════════════════════════════
     CONCEPTS DATA
     ═══════════════════════════════════════ */
  const concepts = [
    {
      icon: '∞', term: 'Éternité / Qidam', arabic: 'قِدَم',
      def: 'Le <strong>qidam</strong> désigne l\'éternité <em>a parte ante</em> — l\'absence de commencement. Les philosophes l\'attribuent à l\'univers (hérésie selon Ghazâlî). Dans le kalâm, seul Dieu est qadîm (éternel). Le monde, lui, est <em>hâdith</em> — advenu, créé.'
    },
    {
      icon: '⬡', term: 'Emanation / Fayd', arabic: 'فَيْض',
      def: 'Le <strong>fayd</strong> est la doctrine néoplatonicienne selon laquelle le monde procède nécessairement de Dieu comme la lumière du soleil. Cette émanation est <em>nécessaire</em> (non libre). Ghazâlî y voit la destruction de la volonté divine : un Dieu dont la création est forcée n\'est pas le Dieu de l\'islam.'
    },
    {
      icon: '◎', term: 'Occasionnalisme / ʿâda', arabic: 'العادة',
      def: 'Dans la Q.17 sur la causalité, Ghazâlî défend que Dieu est la seule cause réelle de tous les événements. Le feu ne brûle pas par lui-même — c\'est <em>l\'habitude divine</em> (<strong>ʿâda</strong>) de faire coïncider feu et brûlure. Ghazâlî peut donc maintenir les miracles comme simples <em>ruptures de l\'habitude</em>.'
    },
    {
      icon: '◈', term: 'Kalâm', arabic: 'كَلَام',
      def: 'La <strong>falsafa</strong> désigne la philosophie gréco-arabe (Avicenne, Alpharabius), héritière d\'Aristote. Le <strong>kalâm</strong> est la théologie spéculative islamique, qui utilise la raison pour défendre les dogmes. Ghazâlî appartient au kalâm asharite, mais le dépasse par sa maîtrise de la falsafa qu\'il combat de l\'intérieur.'
    },
    {
      icon: '✦', term: 'Kashf (illumination soufie)', arabic: 'كَشْف',
      def: 'Le <strong>kashf</strong> est la connaissance directe, intuitive, acquise par la purification spirituelle soufie. C\'est la réponse de Ghazâlî à l\'échec de la raison dans les questions ultimes : là où la démonstration s\'arrête, la lumière divine prend le relais. C\'est le fondement épistémologique de son tournant mystique.'
    },
    {
      icon: '⬛', term: 'Taqlîd (imitation servile)', arabic: 'تَقْلِيد',
      def: 'Le <strong>taqlîd</strong> est l\'imitation aveugle d\'une autorité sans examen critique. Ghazâlî le combat dans les deux sens : il refuse le taqlîd religieux naïf <em>et</em> le taqlîd philosophique (suivre Avicenne sans critique). La liberté intellectuelle est pour lui une condition de la vérité : <em>«&nbsp;celui qui ne doute pas ne réfléchit pas&nbsp;»</em>.'
    },
    {
      icon: '◇', term: 'Hâdith (adventicité)', arabic: 'حُدُوث',
      def: 'L\'<strong>adventicité</strong> (hudûth) désigne le fait d\'être créé, d\'avoir un commencement dans le temps. Pour la théologie islamique, le monde est hâdith — il a commencé par un acte créateur libre de Dieu. S\'y oppose le <em>qidam</em> (éternité). La preuve de l\'existence de Dieu dans le kalâm part souvent de l\'adventicité du monde.'
    },
    {
      icon: '⚡', term: 'Kufr (hérésie / apostasie)', arabic: 'كُفْر',
      def: 'Le <strong>kufr</strong> désigne le rejet des principes fondamentaux de la foi islamique. Ghazâlî est très précis : seules <em>trois</em> des vingt questions relèvent du kufr (hérésie formelle). Les autres constituent au pire une <em>bid\'a</em> (innovation blâmable). Cette distinction montre sa rigueur catégorielle : il ne pratique pas l\'excommunication à la légère.'
    },
  ];

  let openedConcepts = new Set();
  const ccGrid = document.getElementById('ccGrid');
  if (ccGrid) {
    concepts.forEach((c, i) => {
      const div = document.createElement('div');
      div.className = 'cc';
      div.innerHTML = `
        <div class="cc-head">
          <div class="cc-icon">${c.icon}</div>
          <div class="cc-meta">
            <div class="cc-term">${c.term}</div>
            <div class="cc-arabic-term">${c.arabic}</div>
          </div>
          <div class="cc-toggle" id="cct${i}">▸ <span>Définir</span></div>
        </div>
        <div class="cc-body" id="ccb${i}">
          <div class="cc-def">${c.def}</div>
        </div>
      `;
      div.addEventListener('click', () => {
        const body = document.getElementById('ccb' + i);
        const tog  = document.getElementById('cct' + i);
        if (body && tog) {
          const span = tog.querySelector('span');
          const isOpen = body.classList.toggle('open');
          tog.classList.toggle('open-arrow', isOpen);
          if (tog.firstChild) tog.firstChild.textContent = isOpen ? '▾ ' : '▸ ';
          if (span) span.textContent = isOpen ? 'Réduire' : 'Définir';
          if (isOpen) { openedConcepts.add(i); updateConceptCount(); }
        }
      });
      ccGrid.appendChild(div);
    });
  }

  function updateConceptCount() {
    const total = openedQs.size + openedConcepts.size;
    const max = 8;
    const shown = Math.min(total, max);
    const conceptCount = document.getElementById('conceptCount');
    const conceptFill = document.getElementById('conceptFill');
    if (conceptCount) conceptCount.textContent = `${shown}/${max}`;
    if (conceptFill) conceptFill.style.width = `${(shown/max)*100}%`;
  }

  /* ═══════════════════════════════════════
     QUIZ DATA
     ═══════════════════════════════════════ */
  const quizData = [
    {
      q: "Quelle est la méthode principale du Tahâfut ? Ghazâlî réfute les philosophes en :",
      opts: [
        "Opposant des textes coraniques à leurs arguments",
        "Invoquant l'autorité des hadith prophétiques",
        "Démontrant l'infériorité de la philosophie grecque face à la philosophie islamique",
        "Les battant sur leur propre terrain logique, montrant leurs contradictions internes"
      ],
      correct: 3,
      feedback: "Exact. La force du Tahâfut est précisément sa méthode interne : Ghazâlî maîtrise la philosophie aristotélicienne et démontre, avec ses propres outils logiques, qu'Avicenne et Alpharabius ne peuvent pas prouver leurs thèses métaphysiques selon leurs propres critères. C'est une réfutation ad hominem philosophique, non une réfutation scripturaire."
    },
    {
      q: "Pour Ghazâlî, combien des vingt questions constituent une hérésie (<em>kufr</em>) justifiant de taxer les philosophes d'apostasie ?",
      opts: [
        "Trois questions seulement",
        "Les vingt questions toutes entières",
        "Dix questions — la moitié",
        "Une seule question — l'éternité du monde"
      ],
      correct: 0,
      feedback: "Précisément. Ghazâlî est très rigoureux dans sa catégorisation : seules trois questions relèvent du kufr (Q.1 : éternité du monde ; Q.13 : Dieu ne connaît pas les particuliers ; Q.20 : négation de la résurrection corporelle). Les autres constituent des erreurs ou des innovations blâmables, mais pas des hérésies formelles. Cette précision montre qu'il ne pratique pas l'excommunication à la légère."
    },
    {
      q: "Dans la Question 17 sur la causalité naturelle, quelle est la thèse de Ghazâlî concernant le rapport entre le feu et la brûlure ?",
      opts: [
        "Le feu brûle par une nécessité naturelle propre à sa nature",
        "Il n'y a pas de lien nécessaire entre feu et brûlure : Dieu crée la brûlure à chaque fois par habitude divine (ʿâda)",
        "Le feu ne brûle que si un être humain l'allume — causalité humaine",
        "La brûlure est une illusion des sens — seule la forme intelligible de la chaleur est réelle"
      ],
      correct: 1,
      feedback: "Parfait. C'est l'un des passages les plus célèbres et les plus influents du Tahâfut. Ghazâlî défend une position occasionnaliste : Dieu est la seule cause réelle de tous les événements. Ce qu'on appelle 'causalité naturelle' est en réalité l'habitude (ʿâda) de Dieu de faire coïncider certains événements. Cela lui permet de maintenir la possibilité des miracles comme simples 'ruptures de l'habitude divine'. Cette thèse a fasciné Hume et les philosophes analytiques contemporains."
    },
    {
      q: "Quelle est la doctrine d'Avicenne sur la connaissance divine des particuliers, que Ghazâlî classe comme hérésie ?",
      opts: [
        "Dieu ignore totalement l'existence du monde individuel",
        "Dieu connaît les particuliers avec une précision absolue et individualisée",
        "Dieu ne connaît que l'avenir, non le présent ni le passé",
        "Dieu connaît les particuliers seulement de manière universelle, non dans leur singularité"
      ],
      correct: 3,
      feedback: "Exact. Avicenne soutient que Dieu connaît les choses singulières (individus, événements particuliers) seulement sub specie universali — de manière universelle et non individuelle. Pour Ghazâlî, cette position implique que Dieu ignore les prières de chaque individu, les actes particuliers de chaque croyant, et l'histoire singulière de chaque âme. C'est nier la Providence et rendre la révélation prophétique impossible."
    },
    {
      q: "Comment Ghazâlî se distingue-t-il de Descartes dans son usage du doute, selon Abd al-Rahmân Badawi ?",
      opts: [
        "Le doute de Ghazâlî est plus radical car il remet en cause même les vérités mathématiques",
        "Ghazâlî et Descartes ont exactement la même méthode du doute — seules leurs conclusions diffèrent",
        "Le doute de Ghazâlî est mystique et théologique — une profusion de lumière dépassant la raison. Le doute cartésien est méthodologique et conduit au cogito",
        "Ghazâlî doute de l'existence du monde extérieur, Descartes non"
      ],
      correct: 2,
      feedback: "Précisément. Badawi réfute vigoureusement le parallèle Ghazâlî-Descartes, souvent établi par des orientalistes. Le doute de Ghazâlî est une situation psychologique temporaire qui l'a conduit à chercher une certitude au-delà de la raison — dans la lumière divine. Le doute cartésien est une méthode délibérée pour reconstruire le savoir sur des bases rationnelles indubitables. Les deux démarches sont inverses dans leur finalité."
    },
    {
      q: "Que signifie l'accusation centrale du Tahâfut sur l'éternité du monde ?",
      opts: [
        "Que l'univers finira un jour, contrairement à ce qu'enseigne le Coran",
        "Que l'univers n'a pas de début dans le temps, ce qui contredit la Création libre de Dieu",
        "Que Dieu a créé plusieurs univers successifs, non un seul",
        "Que la matière est éternelle mais que la forme cosmique est adventice"
      ],
      correct: 1,
      feedback: "Exact. Si l'univers est éternel — sans commencement — alors il n'a pas été créé. Or la doctrine islamique (et les autres monothéismes) affirme la création libre (creatio ex nihilo) : Dieu a choisi librement de créer le monde à partir du néant. Si la création est éternelle et nécessaire (comme dans la doctrine de l'émanation d'Avicenne), la volonté divine est annulée — Dieu ne choisit pas, il émane nécessairement. Pour Ghazâlî, cela détruit le concept même de Dieu créateur."
    },
    {
      q: "Le Tahâfut a suscité une réfutation célèbre. Laquelle ?",
      opts: [
        "La Métaphysique d'Avicenne, révisée en réponse à Ghazâlî",
        "La Critique de la raison pure de Kant, traduite en arabe au XIXe siècle",
        "Le Tahâfut al-Tahâfut d'Averroès (L'Incohérence de l'Incohérence), 1180",
        "Le Discours de la méthode de Descartes, inspiré par le Munqid"
      ],
      correct: 2,
      feedback: "Très bien. Au XIIe siècle, le philosophe andalou Averroès (Ibn Rushd, 1126–1198) rédige le Tahâfut al-Tahâfut (L'Incohérence de l'Incohérence) pour défendre la philosophie aristotélicienne contre les critiques de Ghazâlî. Ce dialogue à distance — un siècle d'écart — est l'un des grands débats de la pensée médiévale. Ironiquement, en lui consacrant un ouvrage entier, Averroès reconnaît l'extrême sérieux des arguments ghazaliens."
    }
  ];

  let currentQ = 0, score = 0, answered = false;

  window.renderQuestion = function() {
    const q = quizData[currentQ];
    const qNum = document.getElementById('qNum');
    const qText = document.getElementById('qText');
    const qFeedback = document.getElementById('qFeedback');
    const qNext = document.getElementById('qNext') as HTMLButtonElement;
    const qStatus = document.getElementById('qStatus');
    const quizProgressFill = document.getElementById('quizProgressFill');

    if (qNum) qNum.textContent = String(currentQ + 1);
    if (qText) qText.innerHTML = q.q;
    if (qFeedback) {
      qFeedback.className = 'quiz-feedback';
      qFeedback.textContent = '';
    }
    if (qNext) qNext.disabled = true;
    if (qStatus) qStatus.textContent = 'Sélectionnez une réponse';
    answered = false;
    
    if (quizProgressFill) {
      quizProgressFill.style.width = ((currentQ / quizData.length) * 100) + '%';
    }

    const opts = document.getElementById('qOptions');
    if (opts) {
      opts.innerHTML = '';
      q.opts.forEach((opt, i) => {
        const btn = document.createElement('button');
        btn.className = 'qopt';
        btn.innerHTML = `<span>${opt}</span>`;
        btn.onclick = () => window.selectAnswer(i);
        opts.appendChild(btn);
      });
    }
  }

  window.selectAnswer = function(idx: number) {
    if (answered) return;
    answered = true;
    const q = quizData[currentQ];
    
    document.querySelectorAll('.qopt').forEach((o, i) => {
      if (i === q.correct) o.classList.add('correct');
      else if (i === idx && i !== q.correct) o.classList.add('wrong');
      else o.classList.add('reveal');
    });

    const fb = document.getElementById('qFeedback');
    if (fb) {
      fb.textContent = q.feedback;
      fb.classList.add('show');
    }

    const qStatus = document.getElementById('qStatus');
    const scoreDisplay = document.getElementById('scoreDisplay');
    const sidebarScore = document.getElementById('sidebarScore');
    const sidebarFill = document.getElementById('sidebarFill');
    const qNext = document.getElementById('qNext') as HTMLButtonElement;

    if (idx === q.correct) {
      score++;
      if (scoreDisplay) scoreDisplay.textContent = String(score);
      if (qStatus) qStatus.textContent = '✓ Bonne réponse';
    } else {
      if (qStatus) qStatus.textContent = '✗ Réponse incorrecte';
    }
    
    if (qNext) qNext.disabled = false;
    
    const pct = Math.round((score / quizData.length) * 100);
    if (sidebarScore) sidebarScore.textContent = `${score}/${quizData.length}`;
    if (sidebarFill) sidebarFill.style.width = pct + '%';
    
    if (currentQ === quizData.length - 1 && qNext) {
      qNext.textContent = 'Voir mon score →';
    }
  }

  window.nextQuestion = function() {
    currentQ++;
    if (currentQ >= quizData.length) { window.showModal(); return; }
    window.renderQuestion();
  }

  window.showModal = function() {
    const msgs = [
      [0, 1, "Le Tahâfut demande encore votre attention. Revenez sur les 3 hérésies et la méthode de Ghazâlî."],
      [2, 3, "Bonne base. Les nuances entre kufr et bid'a, et la position sur la causalité, méritent relecture."],
      [4, 5, "Solide compréhension. Vous maîtrisez les grandes lignes du Tahâfut."],
      [6, 6, "Excellent. Vous connaissez les thèses, les méthodes et les enjeux du Tahâfut avec précision."],
      [7, 7, "Maîtrise remarquable. Vous êtes prêt(e) à débattre de Ghazâlî avec rigueur philosophique."]
    ];
    const msg = msgs.find(m => score >= m[0] && score <= (m[1] as number));
    
    const modalScore = document.getElementById('modalScore');
    const modalMsg = document.getElementById('modalMsg');
    const modalOverlay = document.getElementById('modalOverlay');

    if (modalScore) modalScore.textContent = `${score}/7`;
    if (modalMsg) modalMsg.textContent = msg ? String(msg[2]) : '';
    if (modalOverlay) modalOverlay.classList.add('show');
  }

  window.closeModal = function() {
    const modalOverlay = document.getElementById('modalOverlay');
    if (modalOverlay) modalOverlay.classList.remove('show');
    
    currentQ = 0; score = 0; answered = false;
    
    const scoreDisplay = document.getElementById('scoreDisplay');
    const quizProgressFill = document.getElementById('quizProgressFill');
    const qNext = document.getElementById('qNext');

    if (scoreDisplay) scoreDisplay.textContent = '0';
    if (quizProgressFill) quizProgressFill.style.width = '0%';
    if (qNext) qNext.textContent = 'Question suivante →';
    
    window.renderQuestion();
  }

  // Initialisation
  window.renderQuestion();
  </script>
</FicheLayout>