---
import FicheLayout from '../../layouts/FicheLayout.astro';

const title = "L'Archéologie du Savoir — Michel Foucault";
const description = "Comment les discours se forment-ils, s'organisent-ils, se transforment-ils ? Foucault forge une méthode : l'archéologie.";
const fonts = "https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Barlow+Condensed:wght@300;400;500;600;700;800;900&family=IBM+Plex+Mono:ital,wght@0,300;0,400;0,500;1,300&display=swap";
---

<FicheLayout title={title} description={description} fonts={fonts}>

  <div id="cur"></div>
  <div id="prog"></div>

  <nav class="snav">
    <div class="snav-brand">
      <div class="snav-kicker">Fiche de lecture</div>
      <div class="snav-title">L'Archéologie<br>du Savoir</div>
      <div class="snav-authors">Michel Foucault</div>
      <div class="snav-year">Gallimard · 1969</div>
    </div>

    <div class="snav-lbl">Navigation</div>
    <a href="#contexte" class="snav-a"><span class="snav-bullet"></span>Contexte & genèse</a>
    <a href="#these" class="snav-a"><span class="snav-bullet"></span>Thèse centrale</a>
    <a href="#structure" class="snav-a"><span class="snav-bullet"></span>Structure du livre</a>
