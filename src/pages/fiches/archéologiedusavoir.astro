  </style>

  <script>
  /* ─── CURSOR ─── */
  const cur = document.getElementById('cur');
  if (cur) {
    document.addEventListener('mousemove', e => {
      cur.style.left = e.clientX + 'px';
      cur.style.top  = e.clientY + 'px';
    });
    document.addEventListener('mouseover', e => {
      const target = e.target as HTMLElement;
      if (target.closest('a,button,.concept-card,.qopt,.acc-head,.gi,.qi')) cur.classList.add('expand');
      else cur.classList.remove('expand');
    });
  }

  /* ─── PROGRESS ─── */
  const prog = document.getElementById('prog');
  if (prog) {
    window.addEventListener('scroll', () => {
      const max = document.body.scrollHeight - window.innerHeight;
      prog.style.transform = `scaleX(${window.scrollY / max})`;
    });
  }

  /* ─── TIMELINE REVEAL ─── */
  const tlObs = new IntersectionObserver(entries => {
    entries.forEach((e, i) => {
      if (e.isIntersecting) {
        setTimeout(() => e.target.classList.add('tl-visible'), i * 120);
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.tl-item').forEach(el => tlObs.observe(el));

  /* ─── ACTIVE NAV ─── */
  const secs = document.querySelectorAll('section[id]');
  const links = document.querySelectorAll('.snav-a');
  const navo = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        links.forEach(l => l.classList.remove('on'));
        const a = document.querySelector(`.snav-a[href="#${e.target.id}"]`);
        if (a) a.classList.add('on');
      }
    });
  }, { threshold: 0.3 });
  secs.forEach(s => navo.observe(s));

  /* ─── ACCORDION ─── */
  window.toggleAcc = function(head: HTMLElement) {
    const item = head.parentElement;
    if (!item) return;
    const wasOpen = item.classList.contains('open');
    if (item.parentElement) {
      item.parentElement.querySelectorAll('.acc-item.open').forEach(i => i.classList.remove('open'));
    }
    if (!wasOpen) item.classList.add('open');
  }

  /* ─── CONCEPT CARDS ─── */
  let openedConcepts = new Set();

  window.toggleCard = function(card: HTMLElement) {
    const expand = card.querySelector('.cc-expand');
    const toggle = card.querySelector('.cc-toggle');
    const num = card.dataset.num;
    if (!expand || !toggle) return;
    
    const isOpen = expand.classList.contains('open');

    expand.classList.toggle('open', !isOpen);
    toggle.classList.toggle('open-arrow', !isOpen);
    const span = toggle.querySelector('span:last-child');
    if (span) {
      span.textContent = isOpen ? 'Lire l\'analyse' : 'Réduire';
    }

    if (!isOpen && num) {
      openedConcepts.add(num);
      updateConceptCount();
    }
  }

  function updateConceptCount() {
    const count = openedConcepts.size;
    const conceptCount = document.getElementById('conceptCount');
    const conceptFill = document.getElementById('conceptFill');
    if (conceptCount) conceptCount.textContent = `${count}/7`;
    if (conceptFill) conceptFill.style.width = `${(count/7)*100}%`;
  }

  /* ─── QUIZ ─── */
  const quizData = [
    {
      q: "Selon Foucault, l'archéologie se distingue de l'histoire des idées principalement parce qu'elle :",
      opts: [
        "Recherche les origines et les fondateurs de chaque pensée",
        "Analyse les influences entre les auteurs et les écoles de pensée",
        "Reconstruit la vision du monde cohérente de chaque époque",
        "Décrit les régularités discursives anonymes, sans chercher de continuité ni de sujet fondateur"
      ],
      correct: 3,
      feedback: "Exact. L'archéologie foucaldienne refuse les trois grands postulats de l'histoire des idées : la continuité (elle souligne les ruptures), le sujet fondateur (elle décrit des régularités anonymes), et l'origine (elle ne cherche aucun fondement premier). Elle décrit des formations discursives — des systèmes de règles qui définissent les conditions d'existence des énoncés."
    },
    {
      q: "La notion d'« énoncé » chez Foucault se distingue de la « phrase grammaticale » et de la « proposition logique » par le fait que :",
      opts: [
        "L'énoncé est une fonction qui attribue à des signes un statut de réalité discursive historiquement situé",
        "L'énoncé est plus court et plus simple que la phrase",
        "L'énoncé est une unité de sens partagée par tous les locuteurs",
        "L'énoncé est défini par sa vérité ou sa fausseté"
      ],
      correct: 0,
      feedback: "Précisément. C'est le grand apport du chapitre II. L'énoncé n'est ni syntaxique (phrase), ni logique (proposition), ni pragmatique au sens classique. C'est une fonction énonciative définie par quatre paramètres : un référentiel, une position de sujet (pas un individu empirique), un champ associé (rapport aux autres énoncés) et une matérialité (support, répétabilité). Ce qui donne à un ensemble de signes le statut d'« événement discursif »."
    },
    {
      q: "L'« archive » telle que Foucault la définit dans L'Archéologie du savoir est :",
      opts: [
        "Le dépôt physique de documents anciens conservés dans une institution",
        "Le système général de la formation et de la transformation des énoncés d'une époque",
        "L'ensemble des textes produits par une civilisation",
        "La mémoire collective d'une société transmise de génération en génération"
      ],
      correct: 1,
      feedback: "Exactement. C'est l'une des redéfinitions les plus originales du livre. L'archive foucaldienne n'est pas un lieu ni une institution — c'est le système général qui régit l'apparition des énoncés comme événements singuliers. Elle définit ce qui peut être dit, comment les discours fonctionnent, ce qui persiste et ce qui disparaît. L'archéologue décrit cette archive depuis un entre-deux temporel : ni le passé trop lointain ni le présent trop proche."
    },
    {
      q: "En quoi la notion d'« a priori historique » constitue-t-elle une rupture avec la philosophie kantienne ?",
      opts: [
        "Kant refusait toute forme d'a priori, tandis que Foucault l'accepte",
        "L'a priori historique est plus rigoureux que l'a priori kantien car il repose sur des faits",
        "Foucault remplace les conditions transcendantales et universelles par des conditions historiquement situées et contingentes",
        "Kant et Foucault partagent la même conception de l'a priori — Foucault se contente d'historiciser"
      ],
      correct: 2,
      feedback: "Parfait. C'est la transformation centrale. Kant posait un a priori universel et nécessaire — les formes pures de l'intuition (espace, temps) et les catégories de l'entendement valent pour tout sujet connaissant, en tout temps. Foucault reprend le geste (il y a bien des conditions de possibilité) mais les rend historiques, contingentes, transformables. Ce n'est plus la structure de la conscience qui définit les conditions de possibilité, mais les configurations historiques des pratiques discursives."
    },
    {
      q: "Foucault distingue entre « savoir » (Wissen) et « connaissance » (Erkenntnis). Laquelle de ces propositions rend compte de cette distinction ?",
      opts: [
        "Le savoir est individuel et intuitif ; la connaissance est collective et institutionnelle",
        "Le savoir désigne le corpus des connaissances vérifiées ; la connaissance désigne les pratiques discursives informelles",
        "Il n'y a aucune distinction — Foucault utilise les deux termes de manière interchangeable",
        "Le savoir désigne l'ensemble des pratiques discursives d'une époque qui définissent les objets possibles ; la connaissance est le savoir formalisé en discipline"
      ],
      correct: 3,
      feedback: "Exact. Cette distinction est cruciale pour comprendre le projet archéologique. Le savoir (Wissen) est plus large et plus fondamental que la connaissance (Erkenntnis) : il désigne l'ensemble des conditions discursives qui définissent ce dont il est possible de parler, depuis quelles positions, avec quels concepts. Une discipline comme la psychiatrie ou l'économie politique « tient » sur un fond de savoir qui la précède et la rend possible. L'archéologie décrit ce fond de savoir."
    },
    {
      q: "Pourquoi Foucault refuse-t-il d'être qualifié de « structuraliste » ?",
      opts: [
        "Le structuralisme cherche des structures profondes universelles ; Foucault décrit des régularités historiques contingentes et transformables",
        "Il trouve le structuralisme trop mathématique et pas assez littéraire",
        "Il préfère s'identifier au marxisme et à la philosophie de l'histoire",
        "Il n'y a aucune différence réelle — le refus de Foucault est purement rhétorique"
      ],
      correct: 0,
      feedback: "Précisément. C'est l'une des clarifications centrales de l'Archéologie du savoir. Le structuralisme (Lévi-Strauss, Lacan, Jakobson) cherche des structures profondes, inconscientes, souvent trans-historiques ou universelles — la grammaire profonde des mythes, les structures élémentaires de la parenté, l'inconscient structuré comme un langage. Foucault, lui, décrit des régularités historiquement situées, contingentes, spécifiques à une époque et un espace social. Elles n'ont rien d'universel et elles sont transformables — par là même, Foucault ouvre la voie à la politique."
    }
  ];

  let currentQ = 0, score = 0, answered = false;

  window.renderQuestion = function() {
    const q = quizData[currentQ];
    const qNum = document.getElementById('qNum');
    const qText = document.getElementById('qText');
    const qFeedback = document.getElementById('qFeedback');
    const qNext = document.getElementById('qNext') as HTMLButtonElement;
    const qStatus = document.getElementById('qStatus');
    const quizProgressFill = document.getElementById('quizProgressFill');

    if (qNum) qNum.textContent = String(currentQ + 1);
    if (qText) qText.textContent = q.q;
    if (qFeedback) {
      qFeedback.className = 'quiz-feedback';
      qFeedback.textContent = '';
    }
    if (qNext) qNext.disabled = true;
    if (qStatus) qStatus.textContent = 'Sélectionnez une réponse';
    answered = false;

    if (quizProgressFill) {
      const pct = (currentQ / quizData.length) * 100;
      quizProgressFill.style.width = pct + '%';
    }

    const opts = document.getElementById('qOptions');
    if (opts) {
      opts.innerHTML = '';
      q.opts.forEach((opt, i) => {
        const btn = document.createElement('button');
        btn.className = 'qopt';
        btn.innerHTML = `<span>${opt}</span>`;
        btn.onclick = () => window.selectAnswer(i);
        opts.appendChild(btn);
      });
    }
  }

  window.selectAnswer = function(idx: number) {
    if (answered) return;
    answered = true;
    const q = quizData[currentQ];
    const opts = document.querySelectorAll('.qopt');

    opts.forEach((o, i) => {
      if (i === q.correct) o.classList.add('correct');
      else if (i === idx && i !== q.correct) o.classList.add('wrong');
      else o.classList.add('reveal');
    });

    const fb = document.getElementById('qFeedback');
    if (fb) {
      fb.textContent = q.feedback;
      fb.classList.add('show');
    }

    const qStatus = document.getElementById('qStatus');
    const scoreDisplay = document.getElementById('scoreDisplay');
    const sidebarScore = document.getElementById('sidebarScore');
    const sidebarFill = document.getElementById('sidebarFill');
    const qNext = document.getElementById('qNext') as HTMLButtonElement;

    if (idx === q.correct) {
      score++;
      if (scoreDisplay) scoreDisplay.textContent = String(score);
      if (qStatus) qStatus.textContent = '✓ Bonne réponse';
    } else {
      if (qStatus) qStatus.textContent = '✗ Réponse incorrecte';
    }

    if (qNext) qNext.disabled = false;

    const pct = Math.round((score / quizData.length) * 100);
    if (sidebarScore) sidebarScore.textContent = `${score}/${quizData.length}`;
    if (sidebarFill) sidebarFill.style.width = pct + '%';

    if (currentQ === quizData.length - 1 && qNext) {
      qNext.textContent = 'Voir mon score →';
    }
  }

  window.nextQuestion = function() {
    currentQ++;
    if (currentQ >= quizData.length) { window.showModal(); return; }
    window.renderQuestion();
  }

  window.showModal = function() {
    const msgs = [
      [0,1, "Prenez le temps de relire la thèse centrale et les définitions de l'énoncé et de la formation discursive. Le cœur conceptuel reste à découvrir."],
      [2,3, "Quelques notions restent floues. Revenez sur la distinction archive / a priori historique et sur la différence avec le structuralisme."],
      [4,4, "Bonne compréhension générale. Approfondissez la distinction savoir/connaissance et la question du sujet."],
      [5,5, "Très solide. Vous saisissez bien l'articulation entre formation discursive, archive et a priori historique."],
      [6,6, "Maîtrise remarquable. Vous pouvez désormais mobiliser ces concepts dans l'analyse de discours contemporains."]
    ];
    const msg = msgs.find(m => score >= m[0] && score <= (m[1] as number));
    
    const modalScore = document.getElementById('modalScore');
    const modalMsg = document.getElementById('modalMsg');
    const modalOverlay = document.getElementById('modalOverlay');

    if (modalScore) modalScore.textContent = `${score}/6`;
    if (modalMsg) modalMsg.textContent = msg ? String(msg[2]) : '';
    if (modalOverlay) modalOverlay.classList.add('show');
  }

  window.closeModal = function() {
    const modalOverlay = document.getElementById('modalOverlay');
    if (modalOverlay) modalOverlay.classList.remove('show');
    
    currentQ = 0; score = 0; answered = false;
    
    const scoreDisplay = document.getElementById('scoreDisplay');
    const quizProgressFill = document.getElementById('quizProgressFill');
    const qNext = document.getElementById('qNext');

    if (scoreDisplay) scoreDisplay.textContent = '0';
    if (quizProgressFill) quizProgressFill.style.width = '0%';
    if (qNext) qNext.textContent = 'Question suivante →';
    
    window.renderQuestion();
  }

  // Initialize UI
  window.renderQuestion();

  window.addEventListener('load', () => {
    setTimeout(() => {
      const sf = document.getElementById('sidebarFill');
      const cf = document.getElementById('conceptFill');
      if (sf) sf.style.width = '0%';
      if (cf) cf.style.width = '0%';
    }, 500);
  });
  </script>
</FicheLayout>