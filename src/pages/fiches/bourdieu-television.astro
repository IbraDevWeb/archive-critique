      font-size: clamp(4rem, 8vw, 9rem);
      font-weight: 300;
      line-height: 0.9;
      letter-spacing: -0.02em;
      opacity: 0; animation: up 0.9s ease forwards 0.3s;
    }

    .hero-h1 em {
      font-style: italic;
      color: var(--rouge);
    }

    .hero-divider {
      width: 80px; height: 1px;
      background: var(--rouge);
      margin: 3rem 0 2rem;
      opacity: 0; animation: fadeIn 1s ease forwards 0.7s;
    }

    .hero-intro {
      max-width: 620px;
      font-size: 1.15rem;
      font-weight: 300;
      color: rgba(250,247,242,0.65);
      line-height: 1.85;
      opacity: 0; animation: up 0.9s ease forwards 0.5s;
    }

    .hero-intro strong { color: var(--paper); font-weight: 400; }

    .hero-bottom {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      padding-top: 4rem;
      border-top: 1px solid rgba(255,255,255,0.08);
      opacity: 0; animation: fadeIn 1s ease forwards 1.2s;
    }

    .hero-meta {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.12em;
      color: rgba(250,247,242,0.3);
      text-transform: uppercase;
      line-height: 2;
    }

    .hero-quote {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      font-style: italic;
      color: rgba(250,247,242,0.5);
      text-align: right;
      max-width: 340px;
      line-height: 1.6;
    }

    .hero-quote cite {
      display: block;
      font-style: normal;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--or);
      margin-top: 0.5rem;
    }

    /* SECTIONS */
    .section {
      padding: 6rem 5rem;
      border-bottom: 1px solid var(--gris-clair);
    }

    .section:nth-child(even) { background: var(--paper2); }
    .section:nth-child(odd) { background: var(--paper); }

    .section-eyebrow {
      display: flex;
      align-items: center;
      gap: 1.2rem;
      margin-bottom: 3.5rem;
    }

    .section-num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.15em;
      color: var(--rouge);
      background: var(--rouge-pale);
      padding: 0.3rem 0.8rem;
      border-radius: 2px;
      text-transform: uppercase;
    }

    .section-h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.8rem;
      font-weight: 600;
      line-height: 1.1;
    }

    .section-h2 em { font-style: italic; color: var(--rouge); }

    /* OBJECTIFS */
    #objectifs {
      background: var(--encre) !important;
      color: var(--paper);
    }

    #objectifs .section-num { background: rgba(181,36,28,0.2); color: #f08077; }

    .objectifs-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.06);
      margin-top: 0.5rem;
    }

    .obj-card {
      background: var(--encre);
      padding: 2.5rem;
      position: relative;
      transition: background 0.3s;
    }
    .obj-card:hover { background: rgba(255,255,255,0.04); }

    .obj-icon {
      font-size: 2rem;
      margin-bottom: 1.2rem;
      display: block;
    }

    .obj-num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.55rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--or);
      margin-bottom: 0.8rem;
      display: block;
    }

    .obj-title {
      font-family: 'Syne', sans-serif;
      font-size: 0.9rem;
      font-weight: 600;
      margin-bottom: 0.8rem;
      color: var(--paper);
      letter-spacing: 0.01em;
    }

    .obj-text {
      font-size: 0.9rem;
      color: rgba(250,247,242,0.55);
      line-height: 1.7;
      font-family: 'Cormorant Garamond', serif;
    }

    /* GLOSSAIRE */
    .glossaire-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2px;
      background: var(--gris-clair);
      border: 1px solid var(--gris-clair);
    }

    .glossaire-item {
      background: var(--paper);
      padding: 2.5rem;
      position: relative;
      overflow: hidden;
      transition: background 0.3s;
    }

    .section:nth-child(even) .glossaire-item { background: var(--paper2); }

    .glossaire-item::before {
      content: attr(data-letter);
      position: absolute;
      right: 1.5rem; bottom: -0.5rem;
      font-family: 'Cormorant Garamond', serif;
      font-size: 8rem;
      font-weight: 700;
      color: rgba(181,36,28,0.04);
      line-height: 1;
      pointer-events: none;
    }

    .glossaire-item:hover { background: var(--rouge-pale); }

    .g-tag {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.55rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--rouge);
      margin-bottom: 0.5rem;
      display: block;
    }

    .g-term {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.6rem;
      font-weight: 700;
      margin-bottom: 1rem;
      line-height: 1.2;
    }

    .g-def {
      font-size: 0.95rem;
      line-height: 1.75;
      color: #3a3530;
    }

    .g-example {
      margin-top: 1rem;
      padding: 0.8rem 1rem;
      background: rgba(181,36,28,0.06);
      border-left: 2px solid var(--rouge);
      font-style: italic;
      font-size: 0.88rem;
      color: var(--gris);
    }

    /* THÈMES */
    .theme-block {
      margin-bottom: 4rem;
      display: grid;
      grid-template-columns: 120px 1fr;
      gap: 0 3rem;
      align-items: start;
    }

    .theme-block:last-child { margin-bottom: 0; }

    .theme-letter-big {
      font-family: 'Cormorant Garamond', serif;
      font-size: 6rem;
      font-weight: 700;
      color: var(--rouge);
      line-height: 1;
      opacity: 0.15;
      text-align: center;
      padding-top: 0.2rem;
    }

    .theme-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1.2rem;
      flex-wrap: wrap;
    }

    .theme-badge {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.55rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      padding: 0.25rem 0.7rem;
      border-radius: 2px;
    }

    .badge-rouge { background: var(--rouge-pale); color: var(--rouge); }
    .badge-or    { background: #fdf3dc; color: var(--or); }
    .badge-vert  { background: #dff0e8; color: var(--vert); }
    .badge-encre { background: #dce4f0; color: var(--encre); }

    .theme-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.5rem;
      font-weight: 700;
    }

    .theme-body {
      font-size: 0.95rem;
      color: #3a3530;
      line-height: 1.85;
    }

    .theme-body p { margin-bottom: 0.8rem; }
    .theme-body p:last-child { margin-bottom: 0; }
    .theme-body strong { color: var(--ink); font-weight: 600; }
    .theme-body em { color: var(--rouge); font-style: italic; }

    /* CITATION FLOTTANTE */
    .pull-quote {
      margin: 3rem 0;
      padding: 2.5rem 3rem;
      background: var(--ink);
      color: var(--paper);
      position: relative;
      overflow: hidden;
    }

    .pull-quote::before {
      content: '\201C';
      position: absolute;
      top: -1rem; left: 1.5rem;
      font-family: 'Cormorant Garamond', serif;
      font-size: 10rem;
      color: var(--rouge);
      opacity: 0.2;
      line-height: 1;
    }

    .pull-quote p {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.4rem;
      font-style: italic;
      font-weight: 300;
      line-height: 1.65;
      position: relative;
      z-index: 1;
    }

    .pull-quote cite {
      display: block;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--or);
      margin-top: 1rem;
      font-style: normal;
    }

    /* SCHÉMA CIRCULATION */
    .schema-section {
      background: var(--encre) !important;
      color: var(--paper);
    }

    .schema-section .section-h2 { color: var(--paper); }
    .schema-section .section-num { background: rgba(196,150,42,0.2); color: var(--or); }

    .schema-wrapper {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 4px;
      padding: 3rem;
      margin-top: 2rem;
      overflow: hidden;
    }

    /* DÉBAT SECTION */
    .debat-intro {
      font-size: 1rem;
      color: var(--gris);
      margin-bottom: 3rem;
      max-width: 720px;
      line-height: 1.8;
    }

    .debat-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      margin-bottom: 3rem;
    }

    .debat-col-title {
      font-family: 'Syne', sans-serif;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--rouge);
      margin-bottom: 1.5rem;
      padding-bottom: 0.8rem;
      border-bottom: 2px solid var(--rouge);
    }

    .debat-list {
      list-style: none;
    }

    .debat-list li {
      font-size: 0.9rem;
      line-height: 1.7;
      padding: 0.8rem 0 0.8rem 1.5rem;
      border-bottom: 1px solid var(--gris-clair);
      position: relative;
      color: #3a3530;
    }

    .debat-list li::before {
      content: '—';
      position: absolute; left: 0;
      color: var(--rouge);
      font-family: 'JetBrains Mono', monospace;
    }

    .tools-presenter {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-top: 2rem;
    }

    .tool-card {
      background: var(--ink);
      color: var(--paper);
      padding: 2rem;
      position: relative;
      overflow: hidden;
    }

    .tool-card::after {
      content: attr(data-icon);
      position: absolute;
      right: 1rem; bottom: 0.5rem;
      font-size: 3rem;
      opacity: 0.1;
    }

    .tool-card-num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.55rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--or);
      display: block;
      margin-bottom: 0.5rem;
    }

    .tool-card-title {
      font-family: 'Syne', sans-serif;
      font-size: 0.82rem;
      font-weight: 600;
      margin-bottom: 0.7rem;
      color: var(--paper);
    }

    .tool-card-desc {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.88rem;
      color: rgba(250,247,242,0.6);
      line-height: 1.65;
    }

    /* RÉFLEXIONS */
    .reflexion-section {
      background: var(--encre) !important;
      color: var(--paper);
    }

    .reflexion-section .section-h2 { color: var(--paper); }
    .reflexion-section .section-num { background: rgba(196,150,42,0.2); color: var(--or); }

    .reflexion-intro {
      font-size: 1rem;
      color: rgba(250,247,242,0.55);
      margin-bottom: 3rem;
      max-width: 700px;
      font-style: italic;
      line-height: 1.8;
    }

    .questions-stack {
      display: flex;
      flex-direction: column;
      gap: 2px;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.05);
    }

    .question-item {
      background: rgba(255,255,255,0.02);
      padding: 2.5rem 3rem;
      display: grid;
      grid-template-columns: 80px 1fr;
      gap: 2rem;
      align-items: start;
      transition: background 0.3s;
    }
    .question-item:hover { background: rgba(181,36,28,0.08); }

    .q-num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--rouge);
      padding-top: 0.3rem;
    }

    .q-text {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.15rem;
      font-style: italic;
      color: var(--paper);
      line-height: 1.7;
      margin-bottom: 0.7rem;
    }

    .q-hint {
      font-family: 'Syne', sans-serif;
      font-size: 0.72rem;
      color: rgba(250,247,242,0.35);
      font-style: normal;
      font-weight: 400;
      line-height: 1.6;
    }

    .q-concepts {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      margin-top: 0.8rem;
    }

    .q-concept-tag {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.55rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--or);
      border: 1px solid rgba(196,150,42,0.3);
      padding: 0.2rem 0.6rem;
      border-radius: 2px;
    }

    /* TIMELINE AUDIMAT */
    .audimat-visual {
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 3rem;
      align-items: start;
      margin-top: 1rem;
    }

    .audimat-desc {
      font-size: 0.95rem;
      color: #3a3530;
      line-height: 1.85;
      margin-bottom: 1.5rem;
    }

    .audimat-desc strong { color: var(--ink); }

    .impact-list {
      list-style: none;
      margin-top: 1.5rem;
    }

    .impact-list li {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: 1rem 0;
      border-bottom: 1px solid var(--gris-clair);
      font-size: 0.9rem;
      color: #3a3530;
    }

    .impact-list li:last-child { border-bottom: none; }

    .impact-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--rouge);
      flex-shrink: 0;
      margin-top: 0.45rem;
    }

    /* MÉCANISMES ARROW */
    .mechanism-flow {
      display: flex;
      flex-direction: column;
      gap: 0;
      margin-top: 2rem;
    }

    .mflow-step {
      display: grid;
      grid-template-columns: 50px 1fr;
      gap: 1.5rem;
      align-items: start;
      position: relative;
    }

    .mflow-step::before {
      content: '';
      position: absolute;
      left: 24px; top: 50px;
      width: 2px; height: calc(100% - 20px);
      background: var(--rouge);
      opacity: 0.2;
    }

    .mflow-step:last-child::before { display: none; }

    .mflow-circle {
      width: 50px; height: 50px;
      border-radius: 50%;
      background: var(--rouge);
      color: var(--paper);
      display: flex; align-items: center; justify-content: center;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem;
      font-weight: 500;
      flex-shrink: 0;
      position: relative;
      z-index: 1;
    }

    .mflow-body {
      padding: 0.5rem 0 2.5rem;
    }

    .mflow-title {
      font-family: 'Syne', sans-serif;
      font-size: 0.85rem;
      font-weight: 700;
      margin-bottom: 0.4rem;
      color: var(--ink);
    }

    .mflow-desc {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.9rem;
      color: var(--gris);
      line-height: 1.7;
    }

    /* SYNTHÈSE FINALE */
    .synthese-section {
      background: var(--rouge) !important;
      color: var(--paper);
    }

    .synthese-section .section-h2 { color: var(--paper); }
    .synthese-section .section-num { background: rgba(0,0,0,0.15); color: rgba(250,247,242,0.8); }

    .synthese-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 2rem;
      margin-top: 1rem;
    }

    .synthese-card {
      background: rgba(0,0,0,0.12);
      padding: 2rem;
      border-top: 3px solid rgba(255,255,255,0.2);
      transition: background 0.3s;
    }

    .synthese-card:hover { background: rgba(0,0,0,0.2); }

    .synthese-card-title {
      font-family: 'Syne', sans-serif;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(250,247,242,0.7);
      margin-bottom: 0.8rem;
    }

    .synthese-card-content {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1rem;
      line-height: 1.7;
      color: rgba(250,247,242,0.9);
    }

    /* FOOTER */
    footer {
      background: #0a0907;
      color: rgba(250,247,242,0.3);
      padding: 3rem 5rem;
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.58rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    footer .f-center {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.2rem;
      font-style: italic;
      color: rgba(250,247,242,0.2);
      text-transform: none;
      letter-spacing: 0;
      text-align: center;
    }

    footer a {
      color: var(--rouge);
      text-decoration: none;
      display: block;
      text-align: right;
      transition: color 0.2s;
    }
    footer a:hover { color: var(--or); }

    @media (max-width: 1100px) {
      :root { --sidebar-w: 220px; }
      .hero { padding: 5rem 3.5rem 3.5rem; }
      .section { padding: 5rem 3.5rem; }
      .objectifs-grid { grid-template-columns: 1fr 1fr; }
      .tools-presenter { grid-template-columns: 1fr 1fr; }
      .synthese-grid { grid-template-columns: 1fr 1fr; }
    }

    @media (max-width: 800px) {
      :root { --sidebar-w: 0px; }
      .sidenav { display: none; }
      .hero { padding: 4rem 2rem 3rem; min-height: auto; }
      .section { padding: 4rem 2rem; }
      .objectifs-grid { grid-template-columns: 1fr; }
      .glossaire-layout { grid-template-columns: 1fr; }
      .theme-block { grid-template-columns: 1fr; }
      .theme-letter-big { display: none; }
      .debat-layout { grid-template-columns: 1fr; }
      .tools-presenter { grid-template-columns: 1fr; }
      .audimat-visual { grid-template-columns: 1fr; }
      .synthese-grid { grid-template-columns: 1fr; }
      .question-item { grid-template-columns: 1fr; }
      .q-num { padding-top: 0; }
      footer { grid-template-columns: 1fr; gap: 1rem; text-align: center; }
      footer a { text-align: center; }
      .hero-bottom { flex-direction: column; gap: 2rem; }
      .hero-quote { text-align: left; }
    }
/* ─── CORRECTIONS BOURDIEU ─── */
  
  /* 1. Animations (Rend le texte visible) */
  @keyframes up { from { opacity: 0; transform: translateY(28px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

  /* 2. Curseur (Géométrie complète) */
  .cur { 
    width: 12px; height: 12px; background: var(--rouge) !important; 
    border-radius: 50%; position: fixed; top: 0; left: 0; 
    pointer-events: none; z-index: 9999; transform: translate(-50%,-50%); 
    transition: transform 0.1s ease, width 0.3s ease, height 0.3s ease, background 0.3s; 
    mix-blend-mode: multiply; 
  }
  .cur.big { width: 44px; height: 44px; background: rgba(181,36,28,0.15) !important; }

  </style>
</FicheLayout>